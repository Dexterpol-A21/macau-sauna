---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  seo={{
    title: 'Feature Discontinued | Macau Sauna Booking',
    description: 'This page is no longer available.',
    keywords: '',
    noindex: true,
  }}
>
  <main style="background:#0A0A0A; min-height:60vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:4rem 1.5rem">
    <div>
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(2rem,5vw,3rem); color:#FFF8F0; margin:0 0 1rem">Feature Discontinued</h1>
      <p style="font-family:'Inter',sans-serif; color:#9E9E9E; font-size:1rem; margin:0 0 2rem">This page is no longer available. Head back to explore our venues.</p>
      <a href="/venues" style="display:inline-flex;align-items:center;justify-content:center;padding:0.85rem 2rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;color:#0A0A0A;background:linear-gradient(325deg,#8A6E2E,#DFC878,#9D7815);border-radius:0.5em;transition:transform 0.25s">Explore Venues</a>
    </div>
  </main>
</BaseLayout>
