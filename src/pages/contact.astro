---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SEO_KEYWORDS } from '../utils/constants';
import { TITLE_CONTACT } from '../utils/seo-titles';
import SlotMachineText from '../components/ui/SlotMachineText';
---

<BaseLayout
  seo={{
    title: TITLE_CONTACT,
    description: 'Contact Macau Sauna Booking — WhatsApp, Telegram, WeChat & LINE. Free shuttle, VIP entry, venue recommendations. We reply within minutes.',
    keywords: `Macau sauna booking, contact Macau spa, Macau sauna WhatsApp, Telegram Macau spa, WeChat Macau sauna, LINE Macau spa, ${SEO_KEYWORDS}`,
  }}
>
  <main class="cu-page">
    <section class="cu-hero">
      <div class="cu-hero-wrap">
        <span class="cu-hero-eyebrow">Get in Touch</span>
        <h1 class="cu-hero-title">
          <SlotMachineText text="We'll answer everything" stripLength={16} client:visible />
        </h1>
        <p class="cu-hero-sub">Pick your preferred channel — we reply within minutes, any hour of the day.</p>
      </div>
    </section>

    <section class="cu-channels">
      <div class="cu-channels-wrap">
        <div class="cu-channels-grid">
          <a href="https://wa.me/message/YOURNUMBER" class="cu-card">
            <img src="/whatsapp.svg" alt="" class="cu-card-icon" />
            <div class="cu-card-body">
              <span class="cu-card-label">WhatsApp</span>
              <span class="cu-card-detail">Message us</span>
              <span class="cu-card-hint">Fastest response — we're on WhatsApp 24/7</span>
            </div>
            <svg class="cu-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
          </a>
          <a href="https://t.me/Aomensauna" class="cu-card">
            <img src="/telegram.svg" alt="" class="cu-card-icon" />
            <div class="cu-card-body">
              <span class="cu-card-label">Telegram</span>
              <span class="cu-card-detail">@Aomensauna</span>
              <span class="cu-card-hint">Preferred for file sharing & photos</span>
            </div>
            <svg class="cu-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
          </a>
          <a href="#" class="cu-card">
            <img src="/wechat.svg" alt="" class="cu-card-icon" />
            <div class="cu-card-body">
              <span class="cu-card-label">WeChat</span>
              <span class="cu-card-detail">AN99348</span>
              <span class="cu-card-hint">Best for Chinese-speaking guests</span>
            </div>
            <svg class="cu-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
          </a>
          <a href="https://line.me/ti/p/16880348" class="cu-card">
            <img src="/line.svg" alt="" class="cu-card-icon" />
            <div class="cu-card-body">
              <span class="cu-card-label">LINE</span>
              <span class="cu-card-detail">16880348</span>
              <span class="cu-card-hint">Popular with Japanese & Taiwanese guests</span>
            </div>
            <svg class="cu-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="cu-faq">
      <div class="cu-faq-wrap">
        <h2 class="cu-section-title">Quick Answers</h2>
        <div class="cu-faq-grid">
          <div class="cu-faq-item">
            <h3 class="cu-faq-q">Is this service free?</h3>
            <p class="cu-faq-a">Yes — our concierge service, including venue recommendation, booking, and private car pickup, is completely free. You pay the venue directly at their listed price, which is often lower than walk-in rates thanks to our partner agreements.</p>
          </div>
          <div class="cu-faq-item">
            <h3 class="cu-faq-q">How fast do you reply?</h3>
            <p class="cu-faq-a">We aim to reply within 5 minutes, 24/7. Response time may be slightly longer during peak hours (7 PM–12 AM Macau time), but we always have someone on duty.</p>
          </div>
          <div class="cu-faq-item">
            <h3 class="cu-faq-q">Do I need to book in advance?</h3>
            <p class="cu-faq-a">Not strictly — we can arrange same-day bookings. However, advance notice gives us time to confirm therapist availability and arrange the best pickup time, so a few hours' heads-up is ideal.</p>
          </div>
          <div class="cu-faq-item">
            <h3 class="cu-faq-q">What languages do you speak?</h3>
            <p class="cu-faq-a">English, Mandarin, Cantonese, Japanese, and Korean. Tell us your preferred language when you message and we'll match you with the right concierge.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .cu-page {
    background: #000000;
    color: #FFF8F0;
    font-family: 'Inter', sans-serif;
  }

  /* Hero */
  .cu-hero {
    padding: 7rem 2rem 5rem;
    text-align: center;
  }

  .cu-hero-wrap {
    max-width: 36rem;
    margin: 0 auto;
  }

  .cu-hero-eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #C9A84C;
    margin-bottom: 1.25rem;
  }

  .cu-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  .cu-hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #807860;
    margin: 0;
  }

  /* Channels */
  .cu-channels {
    background: #0A0A0A;
    border-top: 2px solid rgba(201,168,76,0.12);
    padding: 4rem 2rem 5rem;
  }

  .cu-channels-wrap {
    max-width: 48rem;
    margin: 0 auto;
  }

  .cu-channels-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cu-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #000000;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, background 0.3s;
  }

  .cu-card:hover {
    border-color: rgba(201,168,76,0.3);
    background: rgba(201,168,76,0.04);
  }

  .cu-card-icon {
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .cu-card:hover .cu-card-icon {
    transform: scale(1.08);
  }

  .cu-card-body {
    flex: 1;
    min-width: 0;
  }

  .cu-card-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #FFF8F0;
    margin-bottom: 0.15rem;
  }

  .cu-card-detail {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: #9E9E9E;
    margin-bottom: 0.25rem;
  }

  .cu-card-hint {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: #606070;
  }

  .cu-card-arrow {
    flex-shrink: 0;
    color: rgba(201,168,76,0.4);
    transition: color 0.3s, transform 0.3s;
  }

  .cu-card:hover .cu-card-arrow {
    color: #DDB855;
    transform: translate(2px, -2px);
  }

  /* FAQ */
  .cu-faq {
    background: #000000;
    border-top: 2px solid rgba(201,168,76,0.12);
    padding: 5rem 2rem 6rem;
  }

  .cu-faq-wrap {
    max-width: 48rem;
    margin: 0 auto;
  }

  .cu-section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0 0 3rem;
  }

  .cu-faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .cu-faq-item {
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .cu-faq-q {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #FFF8F0;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .cu-faq-a {
    font-family: 'Inter', sans-serif;
    font-size: 0.83rem;
    font-weight: 400;
    color: #807860;
    line-height: 1.65;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .cu-hero { padding: 5rem 1.25rem 3.5rem; }
    .cu-channels { padding: 3rem 1.25rem 4rem; }
    .cu-faq { padding: 3.5rem 1.25rem 4.5rem; }
    .cu-faq-grid { grid-template-columns: 1fr; }
    .cu-card { padding: 1rem 1.25rem; }
  }
</style>
