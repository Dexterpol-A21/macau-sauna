---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ChevronDown, ArrowLeft } from '@lucide/astro';
import { FAQ_DESCRIPTION, FAQ_KEYWORDS } from '../utils/constants';
import { TITLE_FAQ } from '../utils/seo-titles';

type FaqItem = { q: string; a: string };
type FaqCategory = { title: string; items: FaqItem[] };

const FAQ_CATEGORIES: FaqCategory[] = [
  {
    title: 'Getting Started',
    items: [
      { q: 'What is a Macau sauna?', a: 'A modern entertainment spa combining wellness, dining, and leisure. Includes bathing facilities, complimentary dining, a staff selection show, and a 60-minute one-on-one service. Most venues allow 12-15 hour stays, including overnight.' },
      { q: 'Are Macau saunas safe and legal?', a: 'Yes. All mainstream Macau saunas hold a license issued by the Macao Government Tourism Office (MGTO) and undergo regular health, fire, and safety inspections, the same regulatory framework as casinos. You can verify any venue\'s license on the MGTO website.' },
      { q: 'What should I do for my first visit?', a: 'Contact us first! We\'ll recommend the best venue based on your preferences, arrange complimentary transport, and get you exclusive pricing. Walking in alone may mean a 1-2 hour wait and higher prices.' },
    ],
  },
  {
    title: 'Pricing & Payment',
    items: [
      { q: 'How much does it cost?', a: 'Depends on venue and service tier. General range: MOP 1,800 to 7,000+. Vietnamese/Thai: ~MOP 2,400-3,200. Chinese/model: ~MOP 3,200-4,200. Japanese/Korean: ~MOP 5,800-6,800. Contact us for current promotions.' },
      { q: 'Can I book a dual session with two therapists?', a: 'Yes. Choose one therapist and add a second for a dual-service experience. The surcharge varies by venue, Oceanic Royal Spa offers the best value at only +20-30%. Ask us for details when you book.' },
      { q: 'Are there hidden fees?', a: 'Some venues charge 10-15% service fee, themed rooms cost extra (MOP 400-1,000), and costume requests add MOP 200-350. Book through us and we\'ll disclose all costs upfront, no surprises.' },
      { q: 'Can I pay by card?', a: 'Yes. Most venues accept Visa, Mastercard, UnionPay, cash (MOP/HKD), Alipay, WeChat Pay, and Apple Pay. Tip: paying in MOP cash saves 1-3% on exchange fees.' },
    ],
  },
  {
    title: 'Practical Info',
    items: [
      { q: 'What are the operating hours?', a: 'All mainstream saunas operate 24 hours, but staff are on duty from 1:00 PM to 5:00 AM.' },
      { q: 'When are the most staff available?', a: 'Most staff come on duty after 7 PM, offering the widest selection. For a quieter experience, arrive between 3-6 PM.' },
      { q: 'How long is the service?', a: 'Standard service is 60 minutes. Pure massage is 90 minutes.' },
      { q: 'Can I stay overnight?', a: 'Yes. All mainstream saunas offer overnight stays (12-15 hours) with free reclining chairs, meals, and bathing facilities. Majesty Spa is open 24 hours with a comfortable recliner lounge (paid private rest rooms in peak season), the best choice for overnight.' },
      { q: 'Can I store luggage?', a: 'Yes. All venues provide free luggage storage with secure lockers in the changing room.' },
      { q: 'Is food available?', a: 'Yes, completely free and unlimited. The menu spans premium steak, fresh seafood, slow-simmered Cantonese soups, Sichuan-style stir-fries, fried rice, fried noodles, fresh fruit, beer, soft drinks, and snacks. The cuisine leans Hong Kong / Cantonese with Sichuan accents, and Taiwan visitors find it very accessible, many regulars say the steak and fried rice rival outside restaurants. Some venues also serve abalone and fish maw at no extra charge.' },
      { q: 'Which venues have the most Japanese/Korean staff?', a: 'Oceanic Royal Spa and Victoria Sauna have the most Japanese/Korean staff. Number One Sauna also offers them but at higher price tiers.' },
      { q: 'Is the return ride free too?', a: 'Yes, pickup and return are both included at zero cost. Just text us when you\'re ready to leave (after your meal, right after your service, anytime) and we\'ll send the same private car to take you back to your hotel, the airport, the ferry terminal, or anywhere in Macau.' },
    ],
  },
  {
    title: 'Why Contact Us',
    items: [
      { q: 'Why should I book through you?', a: 'We offer: exclusive partner pricing (lower than walk-in), complimentary 7-seater private car pickup AND return anywhere in Macau, 1 complimentary VIP Extra (your choice), priority entry, no front-desk queue, real-time staff availability info, and honest recommendations based on your preferences.' },
      { q: 'Can I cancel last minute?', a: 'Yes, free cancellation, no deposit required.' },
      { q: 'What are the extra services?', a: 'Every booking through us includes 1 complimentary VIP Extra, pick from Back Rubbing, head massage, reflexology, manicure, pedicure, hand massage, and ear cleaning. We let the venue know you\'re coming, simply pick what you want on arrival.' },
    ],
  },
  {
    title: 'Massage & Treatments',
    items: [
      { q: 'Do Macau saunas include a massage?', a: 'Yes. Every Macau sauna booked through us includes a complimentary massage, you choose 1 each visit, including full-body back massage, foot massage (reflexology), head massage and hand massage, all normally charged separately. A 60-minute one-on-one service is provided on top of that.' },
      { q: 'What massages and treatments are included free?', a: 'Each booking lets you pick 1 free: full-body back massage, leg massage, head massage, foot massage, hand massage, manicure, pedicure and ear cleaning. These are normally charged separately (around 200-298 MOP each) but are complimentary when you book through us. The full list is on our ranking page.' },
      { q: 'Is there a foot massage / reflexology?', a: 'Yes, foot massage (reflexology) is one of the free VIP treatments. Pressure-point work revives tired feet, perfect after a bath or sauna. Just tell us when you book and we\'ll have the venue ready for you.' },
      { q: 'Can I get a full-body massage?', a: 'Yes. The full-body back massage is a popular free option, working down the back, neck and shoulders. For a deeper 60-minute one-on-one massage, tell us your preferences and we\'ll match you with the right venue and therapist.' },
      { q: 'Is this a spa or a sauna? What\'s the difference?', a: 'In Macau, \'sauna\' and \'spa\' usually mean the same kind of all-in-one club, bathing, dry and wet steam, free dining, massage treatments and overnight rest in one place, not a standalone steam room or massage shop. All 12 of our partner venues are licensed by the Macao Government Tourism Office.' },
    ],
  },
];

const FAQ_ITEMS = FAQ_CATEGORIES.flatMap((c) => c.items);

const VENUE_LINKS: Record<string, string> = {
  'Oceanic Royal Spa': '/venues/oceanic-royal-spa',
  'Majesty Spa': '/venues/majesty-spa',
  'Victoria Sauna': '/venues/victoria-sauna',
  'Number One Sauna': '/venues/number-one-sauna',
};

function linkVenues(text: string): string {
  let out = text;
  for (const [name, href] of Object.entries(VENUE_LINKS)) {
    out = out.replaceAll(
      name,
      `<a class="faq-venue-link" href="${href}">${name}</a>`,
    );
  }
  return out;
}

const CONTACT_CHANNELS = [
  {
    name: 'WhatsApp',
    detail: 'Message us',
    href: 'https://wa.me/message/YOURNUMBER',
    icon: '/whatsapp.svg',
    external: true,
  },
  {
    name: 'Telegram',
    detail: '@Aomensauna',
    href: 'https://t.me/Aomensauna',
    icon: '/telegram.svg',
    external: true,
  },
  {
    name: 'WeChat',
    detail: 'AN99348',
    href: '/contact',
    icon: '/wechat.svg',
    external: false,
  },
  {
    name: 'LINE',
    detail: '16880348',
    href: 'https://line.me/ti/p/16880348',
    icon: '/line.svg',
    external: true,
  },
];

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
});

const categorized = FAQ_CATEGORIES.map((category, catIndex) => ({
  ...category,
  items: category.items.map((item, itemIndex) => ({
    ...item,
    isFirst: catIndex === 0 && itemIndex === 0,
    answerHtml: linkVenues(item.a),
  })),
}));
---

<BaseLayout
  seo={{
    title: TITLE_FAQ,
    description: FAQ_DESCRIPTION,
    keywords: FAQ_KEYWORDS,
  }}
>
  <script type="application/ld+json" set:html={jsonLdFaq}></script>

  <!-- HERO -->
  <section class="faq-hero">
    <div class="faq-hero-bg" aria-hidden="true"></div>
    <div class="faq-hero-wrap faq-fade-up">
      <a href="/" class="faq-back">
        <ArrowLeft class="faq-back-icon" aria-hidden="true" />
        Back to Home
      </a>
      <h1 class="faq-title">FAQ</h1>
      <p class="faq-sub">
        Macau sauna FAQ: pricing, safety, hours, overnight stays, payment methods and practical info
      </p>
      <div class="faq-accent-rule" aria-hidden="true"></div>
    </div>
  </section>

  <!-- ACCORDIONS -->
  <section class="faq-body">
    <div class="faq-body-wrap">
      {
        categorized.map((category) => (
          <div class="faq-group">
            <h2 class="faq-group-title">
              <span class="faq-group-bar" aria-hidden="true" />
              {category.title}
            </h2>
            <div class="faq-list">
              {category.items.map((item) => (
                <div class:list={['faq-card', { 'is-open': item.isFirst }]}>
                  <details class="faq-details" open={item.isFirst}>
                    <summary class="faq-q">
                      <span class="faq-q-text">{item.q}</span>
                      <ChevronDown class="faq-chevron" aria-hidden="true" />
                    </summary>
                    <div class="faq-answer">
                      <div class="faq-answer-inner">
                        <div class="faq-answer-rule" aria-hidden="true" />
                        <p class="faq-a" set:html={item.answerHtml} />
                      </div>
                    </div>
                  </details>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section id="contact" class="faq-contact">
    <div class="faq-contact-wrap">
      <div class="faq-contact-card">
        <h2 class="faq-contact-title">
          Still Have Questions<span class="faq-contact-q">?</span>
        </h2>
        <p class="faq-contact-sub">Contact us anytime. Happy to help</p>
        <div class="faq-channels">
          {
            CONTACT_CHANNELS.map((ch) => (
              <a
                href={ch.href}
                class="faq-channel"
                {...(ch.external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <span class="faq-channel-icon">
                  <img src={ch.icon} alt="" width="28" height="28" />
                </span>
                <span class="faq-channel-meta">
                  <span class="faq-channel-label">{ch.name}</span>
                  <span class="faq-channel-detail">{ch.detail}</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page-local neon red nightlife palette */
  /* Clears fixed navbar + promo banner */
  .faq-hero {
    position: relative;
    padding: var(--chrome-pad) 1rem 4rem;
    background: #0a0a0a;
  }

  .faq-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, #141414, #0f0f0f, #0a0a0a);
    pointer-events: none;
  }

  .faq-hero-wrap {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin-inline: auto;
  }

  .faq-fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }

  .faq-fade-up.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-fade-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .faq-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .faq-back:hover {
    color: var(--color-primary);
  }

  .faq-back-icon {
    width: 1rem;
    height: 1rem;
  }

  .faq-title {
    margin: 0 0 1rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #fff;
    line-height: 1.15;
  }

  .faq-sub {
    margin: 0;
    max-width: 36rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
  }

  .faq-accent-rule {
    width: 5rem;
    height: 2px;
    margin-top: 1.5rem;
    background: var(--color-primary);
  }

  /* Accordion body */
  .faq-body {
    background: #0a0a0a;
    padding: 0 1rem 5rem;
  }

  .faq-body-wrap {
    max-width: 48rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .faq-group-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 1rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(1.125rem, 2.5vw, 1.25rem);
    font-weight: 600;
    color: #fff;
  }

  .faq-group-bar {
    display: block;
    width: 4px;
    height: 1.25rem;
    border-radius: 999px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-card {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .faq-card.is-open,
  .faq-card:has(.faq-details[open]) {
    border-color: color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .faq-details {
    margin: 0;
  }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 1rem 1.25rem;
    list-style: none;
    cursor: pointer;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.55;
    color: #fff;
    transition: color 0.3s ease;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .faq-details[open] .faq-q {
    color: var(--color-primary);
  }

  .faq-q-text {
    flex: 1;
    text-align: left;
  }

  .faq-chevron {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.3);
    transition: transform 0.35s ease, color 0.3s ease;
  }

  .faq-details[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .faq-answer {
    overflow: hidden;
    height: 0;
    opacity: 0;
  }

  .faq-details[open] .faq-answer {
    height: auto;
    opacity: 1;
  }

  .faq-answer-inner {
    padding: 0 1.25rem 1rem;
  }

  .faq-answer-rule {
    width: 100%;
    height: 1px;
    margin-bottom: 1rem;
    background: rgba(255, 255, 255, 0.05);
  }

  .faq-a {
    margin: 0;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }

  .faq-venue-link {
    color: var(--color-primary);
    text-decoration: none;
    transition: text-decoration-color 0.2s ease;
  }

  .faq-venue-link:hover {
    text-decoration: underline;
  }

  /* Contact CTA */
  .faq-contact {
    background: #0a0a0a;
    padding: 0 1rem 5rem;
    scroll-margin-top: 1.5rem;
  }

  .faq-contact-wrap {
    max-width: 48rem;
    margin-inline: auto;
  }

  .faq-contact-card {
    padding: 2rem 1.5rem;
    text-align: center;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-primary) 10%, transparent);
    background: linear-gradient(to right, #141414, #1a1a1a);
  }

  .faq-contact-title {
    margin: 0 0 1rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 700;
    color: #fff;
  }

  .faq-contact-q {
    color: var(--color-primary);
  }

  .faq-contact-sub {
    margin: 0 0 2rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .faq-channels {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .faq-channel {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 0.65rem;
    text-align: left;
    text-decoration: none;
    border-radius: 0.75rem;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: border-color 0.3s ease;
  }

  .faq-channel:hover {
    border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  .faq-channel-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .faq-channel:hover .faq-channel-icon {
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .faq-channel-icon img {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.35rem;
  }

  .faq-channel-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .faq-channel-label {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .faq-channel-detail {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
  }

  @media (min-width: 640px) {
    .faq-hero {
      padding: calc(var(--chrome-top) + 2.75rem) 1rem 5rem;
    }

    .faq-body {
      padding-bottom: 7rem;
    }

    .faq-contact {
      padding-bottom: 7rem;
    }

    .faq-q {
      padding: 1.25rem 1.5rem;
      font-size: 1rem;
    }

    .faq-answer-inner {
      padding: 0 1.5rem 1.25rem;
    }

    .faq-contact-card {
      padding: 3rem;
    }

    .faq-channels {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 419px) {
    .faq-hero {
      padding-top: var(--chrome-pad);
      padding-bottom: 3rem;
    }

    .faq-q {
      padding: 0.9rem 1rem;
      font-size: 0.82rem;
      gap: 0.65rem;
    }

    .faq-answer-inner {
      padding: 0 1rem 0.9rem;
    }

    .faq-a {
      font-size: 0.8rem;
    }

    .faq-contact-card {
      padding: 1.5rem 1rem;
    }
  }
</style>

<script>
  // @ts-nocheck
  class FAQAccordion {
    constructor() {
      this.items = document.querySelectorAll('.faq-details');
      this.animating = new Set();
      this.init();
    }

    init() {
      this.items.forEach((details) => {
        const answer = details.querySelector('.faq-answer');
        const card = details.closest('.faq-card');
        if (!answer) return;

        if (details.hasAttribute('open')) {
          answer.style.height = answer.scrollHeight + 'px';
          card?.classList.add('is-open');
        }

        const summary = details.querySelector('summary');
        summary.addEventListener('click', (e) => {
          e.preventDefault();
          if (this.animating.has(details)) return;

          if (details.open) {
            this.close(details, answer, card);
          } else {
            this.open(details, answer, card);
          }
        });
      });
    }

    open(details, answer, card) {
      details.open = true;
      card?.classList.add('is-open');
      this.animating.add(details);

      answer.style.height = '0px';
      answer.style.opacity = '0';

      requestAnimationFrame(() => {
        const endHeight = answer.scrollHeight;
        answer.style.transition =
          'height 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease 0.1s';
        answer.style.height = endHeight + 'px';
        answer.style.opacity = '1';
      });

      answer.addEventListener(
        'transitionend',
        () => {
          answer.style.height = 'auto';
          answer.style.transition = '';
          answer.style.opacity = '';
          this.animating.delete(details);
        },
        { once: true },
      );
    }

    close(details, answer, card) {
      this.animating.add(details);
      answer.style.height = answer.scrollHeight + 'px';

      requestAnimationFrame(() => {
        answer.style.transition =
          'height 0.35s cubic-bezier(0.55, 0.085, 0.68, 0.53), opacity 0.2s ease';
        answer.style.height = '0px';
        answer.style.opacity = '0';
      });

      answer.addEventListener(
        'transitionend',
        () => {
          details.open = false;
          card?.classList.remove('is-open');
          answer.style.transition = '';
          answer.style.height = '';
          answer.style.opacity = '';
          this.animating.delete(details);
        },
        { once: true },
      );
    }
  }

  new FAQAccordion();

  const fadeObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          fadeObserver.unobserve(entry.target);
        }
      }
    },
    { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
  );
  document.querySelectorAll('.faq-fade-up:not(.in-view)').forEach((el) => fadeObserver.observe(el));
</script>
