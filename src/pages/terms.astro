---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlotMachineText from '../components/ui/SlotMachineText';
import ContactCTA from '../components/home/ContactCTA';
import { SITE_TITLE } from '../utils/constants';
import { TITLE_TERMS } from '../utils/seo-titles';
---

<BaseLayout
  seo={{
    title: TITLE_TERMS,
    description: `Terms and conditions for ${SITE_TITLE}.`,
    keywords: '',
    noindex: true,
  }}
>
  <section class="lp-section">
    <div class="lp-header">
      <span class="lp-eyebrow">Legal</span>
      <h1 class="lp-title">
        <SlotMachineText text="Terms &amp; Conditions" stripLength={10} client:visible />
      </h1>
    </div>

    <div class="lp-body">

      <h2>1. Acceptance of Terms</h2>
      <p>
        By accessing or using <strong>{SITE_TITLE}</strong> (&ldquo;the Site&rdquo;), you agree to be bound by these Terms &amp; Conditions. If you do not agree, please do not use the Site.
      </p>

      <h2>2. Entertainment Purposes Only</h2>
      <p>
        The Site features interactive elements including a spin-the-wheel game and a slot-machine-style matching tool (&ldquo;the Games&rdquo;). These are provided <strong>for entertainment purposes only</strong>.
      </p>
      <p>
        <strong>The Games do not involve real-money wagering, gambling, betting, or prizes of monetary value.</strong> No real currency is staked, won, or lost. Participation is entirely voluntary and free of charge. The Games are not regulated by any gambling commission or gaming authority.
      </p>

      <h2>3. No Real Gambling</h2>
      <p>
        Nothing on this Site constitutes gambling, gaming, or betting as defined by applicable law. The spin wheel and slot match are visual novelties designed to enhance user experience. Outcomes are generated by client-side code and carry no legal or financial significance.
      </p>
      <p>
        If you are located in a jurisdiction where skill-based or chance-based games are restricted, you acknowledge that these features are purely cosmetic and do not fall under such regulations.
      </p>

      <h2>4. Age Restriction</h2>
      <p>
        This Site is intended for users aged <strong>18 years or older</strong>, or the legal age of majority in your jurisdiction, whichever is higher. By using the Site you confirm you meet this requirement.
      </p>

      <h2>5. Booking &amp; Concierge Service</h2>
      <p>
        We act as an independent concierge connecting you with third-party sauna and spa venues in Macau. We do not own or operate any venue. All bookings are subject to venue availability and their respective policies. Prices displayed are indicative and may vary.
      </p>

      <h2>6. Third-Party Links &amp; Venues</h2>
      <p>
        The Site links to external venues and may reference third-party brands. We are not responsible for the content, policies, or services of any third party. Interactions with venues are at your own discretion.
      </p>

      <h2>7. Intellectual Property</h2>
      <p>
        All content on this Site — including text, graphics, logos, icons, and code — is the property of {SITE_TITLE} or its licensors. Unauthorized reproduction or distribution is prohibited.
      </p>

      <h2>8. Limitation of Liability</h2>
      <p>
        To the fullest extent permitted by law, {SITE_TITLE} shall not be liable for any direct, indirect, incidental, or consequential damages arising from your use of the Site or reliance on any information provided.
      </p>

      <h2>9. Changes to These Terms</h2>
      <p>
        We reserve the right to update these terms at any time. Changes take effect immediately upon posting. Continued use of the Site constitutes acceptance of the revised terms.
      </p>

      <h2>10. Contact</h2>
      <p>
        For questions about these Terms, reach out to us:
      </p>
      <div class="lp-cta">
        <ContactCTA client:load />
      </div>

    </div>
  </section>
</BaseLayout>

<style is:global>
  .lp-section {
    background: #0A0A0A;
    padding: var(--chrome-pad) 1.5rem 6rem;
  }

  .lp-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .lp-eyebrow {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #FF2D55;
    margin-bottom: 0.75rem;
  }

  .lp-title {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #FFF8F0;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .lp-body {
    max-width: 42rem;
    margin: 0 auto;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.92rem;
    font-weight: 400;
    color: #B0A890;
    line-height: 1.75;
  }

  .lp-body h2 {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #FFF8F0;
    letter-spacing: -0.01em;
    margin: 2.5rem 0 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .lp-body h2:first-of-type {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .lp-body p {
    margin: 0 0 1rem;
  }

  .lp-body p:last-child {
    margin-bottom: 0;
  }

  .lp-body strong {
    color: #FF2D55;
    font-weight: 600;
  }

  .lp-cta {
    display: flex;
    justify-content: center;
    padding-top: 2rem;
    margin-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 480px) {
    .lp-section {
      padding: var(--chrome-pad) 1rem 4.5rem;
    }
    .lp-body {
      font-size: 0.85rem;
    }
    .lp-body h2 {
      font-size: 1.05rem;
      margin: 2rem 0 0.6rem;
      padding-top: 1.25rem;
    }
  }
</style>
