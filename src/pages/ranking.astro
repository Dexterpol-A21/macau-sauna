---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RANKING_DESCRIPTION, RANKING_KEYWORDS } from '../utils/constants';
import { TITLE_RANKING } from '../utils/seo-titles';

interface RankVenue {
  slug: string;
  name: string;
  district: string;
  therapists: string;
  hours: string;
  open24h: boolean;
  rating: number;
  priceRange: string;
  serviceFee: string;
  overnight: boolean;
  lounge: boolean;
  ktv: boolean;
  themeRooms: boolean;
  show: boolean;
  isNew: boolean;
}

const RANKING: RankVenue[] = [
  { slug: 'manhao-spa', name: 'Manhao Spa', district: 'Taipa', therapists: 'Multinational', hours: '2:00 PM - 4:00 AM', open24h: false, rating: 5, priceRange: '888 – 5,388', serviceFee: '10%', overnight: false, lounge: false, ktv: false, themeRooms: false, show: true, isNew: true },
  { slug: 'number-nine-spa', name: 'Number Nine Spa', district: 'Macau', therapists: '80+', hours: '5:00 PM - 5:00 AM', open24h: true, rating: 5, priceRange: '2,299 – 5,999', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: true, show: true, isNew: true },
  { slug: 'shang-pin-spa', name: 'Shang Pin Spa', district: 'Taipa', therapists: '90+', hours: '3:00 PM - 5:00 AM', open24h: true, rating: 5, priceRange: '999 – 5,999', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: false, show: false, isNew: false },
  { slug: 'majesty-spa', name: 'Majesty Spa', district: 'Macau', therapists: '70+', hours: '2:00 PM - 5:00 AM', open24h: true, rating: 4, priceRange: '1,099 – 5,899', serviceFee: 'None', overnight: true, lounge: true, ktv: true, themeRooms: true, show: false, isNew: false },
  { slug: 'the-excellent-sauna', name: 'The Excellent Sauna', district: 'Macau', therapists: '40+', hours: '1:00 PM - 5:00 AM', open24h: true, rating: 3, priceRange: '988 – 5,288', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: true, show: false, isNew: false },
  { slug: 'empire-sauna', name: 'Empire Sauna', district: 'Macau', therapists: 'Multinational', hours: '5:00 PM - 6:00 AM', open24h: true, rating: 5, priceRange: '1,088 – 6,388', serviceFee: 'None', overnight: true, lounge: true, ktv: false, themeRooms: true, show: false, isNew: true },
  { slug: 'east-castle-spa', name: 'East Castle Spa', district: 'Macau', therapists: '60+', hours: '3:00 PM - 5:00 AM', open24h: true, rating: 4, priceRange: '2,388 – 6,498', serviceFee: '15%', overnight: true, lounge: true, ktv: false, themeRooms: true, show: false, isNew: false },
  { slug: 'victoria-sauna', name: 'Victoria Sauna', district: 'Macau', therapists: '70+', hours: '1:00 PM - 5:00 AM', open24h: true, rating: 4, priceRange: '2,298 – 6,998', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: false, show: false, isNew: false },
  { slug: 'm-club', name: 'M CLUB', district: 'Macau', therapists: '60+', hours: '3:00 PM - 5:00 AM', open24h: true, rating: 4, priceRange: '2,388 – 6,498', serviceFee: '10%', overnight: true, lounge: true, ktv: true, themeRooms: true, show: false, isNew: false },
  { slug: 'oceanic-royal-spa', name: 'Oceanic Royal Spa', district: 'Taipa', therapists: '140+', hours: '24 hours', open24h: true, rating: 5, priceRange: '2,299 – 7,099', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: true, show: true, isNew: false },
  { slug: 'number-one-sauna', name: 'Number One Sauna', district: 'Macau', therapists: '130+', hours: '1:00 PM - 5:00 AM', open24h: true, rating: 5, priceRange: '2,199 – 7,699', serviceFee: '10%', overnight: true, lounge: true, ktv: false, themeRooms: false, show: true, isNew: false },
  { slug: 'familia-nobre', name: 'Familia Nobre', district: 'Macau', therapists: '80+', hours: '4:00 PM - 6:00 AM', open24h: true, rating: 5, priceRange: '2,388 – 6,988', serviceFee: 'None', overnight: true, lounge: true, ktv: false, themeRooms: false, show: false, isNew: false },
];

const TOP_PICKS = [
  { icon: '🎬', label: 'Best theme rooms', venue: 'The Excellent Sauna', slug: 'the-excellent-sauna', desc: 'DJ booth, cinema, hospital and more scene rooms' },
  { icon: '💰', label: 'Best value', venue: 'Shang Pin Spa', slug: 'shang-pin-spa', desc: 'Free therapist add-on with selected packages, signature Japanese soap bath' },
  { icon: '🎭', label: 'Best show', venue: 'Manhao Spa', slug: 'manhao-spa', desc: 'Hot new Taipa venue with a therapist runway' },
  { icon: '🛏️', label: 'Best for overnight', venue: 'Majesty Spa', slug: 'majesty-spa', desc: 'Open 24h with no service charge, plus KTV rooms' },
  { icon: '✨', label: 'Newest & hottest', venue: 'Number Nine Spa', slug: 'number-nine-spa', desc: '2026 opening with a main-stage LED show' },
];

const INCLUDES = [
  'Free unlimited dining',
  'Free lockers',
  'Bathing, dry & steam sauna',
  'Free private shuttle',
  'Free VIP massages (your choice)',
  'Payment: Cash, Card, WeChat Pay, Alipay',
];

const TREATMENTS = [
  { icon: '🧎‍♀️', name: 'Full-Body Back Massage', price: '298 MOP', desc: 'Body-glide rub down the back, neck and shoulders.' },
  { icon: '🦵', name: 'Leg & Thigh Massage', price: '288 MOP', desc: 'Deep work on quads & hamstrings - perfect after the sauna.' },
  { icon: '💆', name: 'Head Massage', price: '230 MOP', desc: 'Scalp kneading that clears mental fog and headaches.' },
  { icon: '🦶', name: 'Foot Massage (Reflexology)', price: '230 MOP', desc: 'Pressure-point work that revives tired feet.' },
  { icon: '🤚', name: 'Manicure', price: '220 MOP', desc: 'Trim, shape, cuticle care, polish.' },
  { icon: '🧴', name: 'Pedicure', price: '220 MOP', desc: 'Foot soak, nail and cuticle care, light foot rub.' },
  { icon: '🤲', name: 'Hand Massage', price: '200 MOP', desc: 'Releases wrist and forearm tension.' },
  { icon: '👂', name: 'Ear Cleaning', price: '200 MOP', desc: 'Traditional ear-cleaning ritual. Surprisingly relaxing.' },
];

function ratingStars(rating: number): string {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}

const jsonLdRanking = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Macau Sauna & Spa Ranking 2026",
  "description": "All 12 licensed Macau sauna and spa venues ranked and compared: pricing, overnight options, features, and the free treatments included with every booking.",
  "numberOfItems": RANKING.length,
  "itemListOrder": "https://schema.org/ItemListOrderDescending",
  "itemListElement": RANKING.map((v, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": v.name,
    "url": `https://macausauna.com/venues/${v.slug}`,
  })),
});
---

<BaseLayout
  seo={{
    title: TITLE_RANKING,
    description: RANKING_DESCRIPTION,
    keywords: RANKING_KEYWORDS,
  }}
>
  <script type="application/ld+json" set:html={jsonLdRanking}></script>

  <!-- Header -->
  <section class="rk-hero">
    <div class="rk-hero-glow" aria-hidden="true"></div>
    <div class="fade-up rk-inner rk-hero-inner">
      <h1 class="rk-title">Macau Sauna &amp; Spa Ranking 2026 - All 12 Venues Ranked</h1>
      <p class="rk-intro">
        One table for all 12 licensed Macau sauna &amp; spa venues: pricing, overnight
        options and features - plus the free massages and treatments included
        with every booking.
      </p>
      <div class="rk-rule" aria-hidden="true"></div>
    </div>
  </section>

  <!-- Top picks -->
  <section class="rk-block">
    <div class="rk-inner">
      <h2 class="fade-up rk-h2">Top pick for each need</h2>
      <div class="rk-picks">
        {TOP_PICKS.map((pick, i) => (
          <a href={`/venues/${pick.slug}`} class="fade-up rk-pick" style={`--fade-delay: ${(0.05 + i * 0.05).toFixed(2)}s`}>
            <span class="rk-pick-icon" aria-hidden="true">{pick.icon}</span>
            <span class="rk-pick-body">
              <span class="rk-pick-label">{pick.label}</span>
              <span class="rk-pick-venue">{pick.venue}</span>
              <span class="rk-pick-desc">{pick.desc}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Includes -->
  <section class="rk-block rk-block-tight">
    <div class="rk-inner">
      <div class="fade-up rk-includes">
        <h2 class="rk-includes-title">Every one of the 12 venues includes</h2>
        <ul class="rk-includes-list">
          {INCLUDES.map((item) => (
            <li>
              <span class="rk-ok" aria-hidden="true">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Split comparison tables -->
  <section class="rk-block">
    <div class="rk-inner rk-tables">
      <!-- Basics -->
      <div class="fade-up rk-table-block">
        <h2 class="rk-h2">Basics</h2>
        <p class="rk-swipe-tip">← Swipe to see the full table →</p>
        <div class="rk-scroll">
          <table class="rk-table">
            <thead>
              <tr>
                <th class="rk-sticky">Venue</th>
                <th>District</th>
                <th>Therapists</th>
                <th>On-duty hours</th>
                <th>Open 24h</th>
                <th>Rating</th>
              </tr>
            </thead>
            <tbody>
              {RANKING.map((v) => (
                <tr>
                  <th scope="row" class="rk-sticky">
                    <a href={`/venues/${v.slug}`} class="rk-venue">{v.name}</a>
                  </th>
                  <td>{v.district}</td>
                  <td>{v.therapists}</td>
                  <td class="rk-muted">{v.hours}</td>
                  <td>{v.open24h ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                  <td class="rk-stars" aria-label={`${v.rating}/5`}>{ratingStars(v.rating)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Pricing -->
      <div class="fade-up rk-table-block" style="--fade-delay: 0.06s">
        <h2 class="rk-h2">Pricing</h2>
        <p class="rk-swipe-tip">← Swipe to see the full table →</p>
        <div class="rk-scroll">
          <table class="rk-table">
            <thead>
              <tr>
                <th class="rk-sticky">Venue</th>
                <th>Price range (MOP)</th>
                <th>Service fee</th>
              </tr>
            </thead>
            <tbody>
              {RANKING.map((v) => (
                <tr>
                  <th scope="row" class="rk-sticky">
                    <a href={`/venues/${v.slug}`} class="rk-venue">{v.name}</a>
                  </th>
                  <td class="rk-price">{v.priceRange}</td>
                  <td>
                    {v.serviceFee === 'None'
                      ? <span class="rk-ok-label">None</span>
                      : v.serviceFee}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Overnight -->
      <div class="fade-up rk-table-block" style="--fade-delay: 0.1s">
        <h2 class="rk-h2">Overnight</h2>
        <p class="rk-swipe-tip">← Swipe to see the full table →</p>
        <div class="rk-scroll">
          <table class="rk-table">
            <thead>
              <tr>
                <th class="rk-sticky">Venue</th>
                <th>Overnight</th>
                <th>Lounge recliner</th>
              </tr>
            </thead>
            <tbody>
              {RANKING.map((v) => (
                <tr>
                  <th scope="row" class="rk-sticky">
                    <a href={`/venues/${v.slug}`} class="rk-venue">{v.name}</a>
                  </th>
                  <td>{v.overnight ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                  <td>{v.lounge ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Features -->
      <div class="fade-up rk-table-block" style="--fade-delay: 0.14s">
        <h2 class="rk-h2">Features</h2>
        <p class="rk-swipe-tip">← Swipe to see the full table →</p>
        <div class="rk-scroll">
          <table class="rk-table">
            <thead>
              <tr>
                <th class="rk-sticky">Venue</th>
                <th>KTV</th>
                <th>Theme rooms</th>
                <th>Show worth watching</th>
                <th>New</th>
              </tr>
            </thead>
            <tbody>
              {RANKING.map((v) => (
                <tr>
                  <th scope="row" class="rk-sticky">
                    <a href={`/venues/${v.slug}`} class="rk-venue">{v.name}</a>
                  </th>
                  <td>{v.ktv ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                  <td>{v.themeRooms ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                  <td>{v.show ? <span class="rk-ok-label">OK</span> : <span class="rk-dash">–</span>}</td>
                  <td>{v.isNew ? <span class="rk-new" aria-label="New">✦</span> : <span class="rk-dash">–</span>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Free massages -->
  <section class="rk-treatments">
    <div class="rk-inner rk-treatments-inner">
      <h2 class="fade-up rk-h2-lg">Free Massages &amp; Treatments Included With Every Booking</h2>
      <div class="fade-up rk-rule rk-rule-sm" aria-hidden="true"></div>
      <p class="rk-treatments-intro">
        Book any Macau sauna through us and choose 1 of these complimentary treatments free -
        full-body back massage, foot massage, head massage, hand massage and more -
        each normally charged separately.
      </p>
      <div class="rk-treatments-grid">
        {TREATMENTS.map((t, i) => (
          <div class="fade-up rk-treatment" style={`--fade-delay: ${(0.04 + i * 0.05).toFixed(2)}s`}>
            <div class="rk-treatment-top">
              <h3 class="rk-treatment-name">
                <span aria-hidden="true">{t.icon}</span>
                {t.name}
              </h3>
              <span class="rk-treatment-price">
                <span class="rk-strike">{t.price}</span>
                <span class="rk-free">Free</span>
              </span>
            </div>
            <p class="rk-treatment-desc">{t.desc}</p>
          </div>
        ))}
      </div>
      <p class="rk-treatments-note">Exact treatments vary slightly by venue; we confirm availability when you book.</p>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="contact" class="rk-cta-section">
    <div class="rk-inner rk-cta-wrap">
      <div class="fade-up rk-cta-card">
        <h2 class="rk-h2-lg">Not sure which venue fits you?</h2>
        <div class="rk-rule rk-rule-sm rk-rule-center" aria-hidden="true"></div>
        <p class="rk-cta-text">
          Tell us your preferences and budget - we recommend the right fit for free and arrange your shuttle.
        </p>
        <div class="rk-channels">
          <a href="https://wa.me/message/YOURNUMBER" class="rk-channel" target="_blank" rel="noopener noreferrer">
            <span class="rk-channel-icon" aria-hidden="true">
              <img src="/whatsapp.svg" alt="" width="28" height="28" />
            </span>
            <span>
              <span class="rk-channel-label">WhatsApp</span>
              <span class="rk-channel-detail">Message us</span>
            </span>
          </a>
          <a href="https://t.me/Aomensauna" class="rk-channel" target="_blank" rel="noopener noreferrer">
            <span class="rk-channel-icon" aria-hidden="true">
              <img src="/telegram.svg" alt="" width="28" height="28" />
            </span>
            <span>
              <span class="rk-channel-label">Telegram</span>
              <span class="rk-channel-detail">@Aomensauna</span>
            </span>
          </a>
          <a href="/contact" class="rk-channel">
            <span class="rk-channel-icon" aria-hidden="true">
              <img src="/wechat.svg" alt="" width="28" height="28" />
            </span>
            <span>
              <span class="rk-channel-label">WeChat</span>
              <span class="rk-channel-detail">AN99348</span>
            </span>
          </a>
          <a href="https://line.me/ti/p/16880348" class="rk-channel" target="_blank" rel="noopener noreferrer">
            <span class="rk-channel-icon" aria-hidden="true">
              <img src="/line.svg" alt="" width="28" height="28" />
            </span>
            <span>
              <span class="rk-channel-label">LINE</span>
              <span class="rk-channel-detail">16880348</span>
            </span>
          </a>
        </div>
        <a href="/how-it-works" class="rk-guide-link">
          First time at a Macau sauna? Read the guide
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Page tokens — noir + neon red (match index) */
  .rk-hero,
  .rk-block,
  .rk-treatments,
  .rk-cta-section {
    --rk-accent: #FF2D55;
    --rk-accent-light: #FF6B85;
    --rk-bg: #0A0A0A;
    --rk-surface: #141414;
    --rk-ok: #4ADE80;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    color: #FFF8F0;
  }

  .rk-inner {
    max-width: 64rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  /* ── Hero (clears fixed navbar + promo banner) ── */
  .rk-hero {
    position: relative;
    overflow: hidden;
    background: var(--rk-bg);
    padding: var(--chrome-pad) 0 3.5rem;
  }

  .rk-hero-glow {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(0, 0, 0, 0.8), rgba(10, 10, 10, 0.9) 50%, #0A0A0A),
      radial-gradient(ellipse at top, rgba(255, 45, 85, 0.08), transparent 60%);
    pointer-events: none;
  }

  .rk-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rk-title {
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: #FFF8F0;
  }

  .rk-intro {
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    max-width: 42rem;
    line-height: 1.65;
    margin: 0;
  }

  .rk-rule {
    width: 5rem;
    height: 2px;
    background: var(--rk-accent);
    margin-top: 1.5rem;
  }

  .rk-rule-sm {
    width: 4rem;
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  .rk-rule-center {
    margin-inline: auto;
  }

  /* ── Sections ── */
  .rk-block {
    background: var(--rk-bg);
    padding-bottom: 2rem;
  }

  .rk-block-tight {
    padding-bottom: 1.5rem;
  }

  .rk-h2 {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 700;
    color: #FFF8F0;
    margin: 0 0 1rem;
  }

  .rk-h2-lg {
    font-size: clamp(1.5rem, 3.5vw, 1.875rem);
    font-weight: 700;
    color: #FFF8F0;
    margin: 0 0 1rem;
  }

  /* ── Top picks ── */
  .rk-picks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .rk-pick {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--rk-surface);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s;
  }

  .rk-pick:hover {
    border-color: rgba(255, 45, 85, 0.3);
  }

  .rk-pick-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .rk-pick-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .rk-pick-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.025em;
    color: var(--rk-accent);
  }

  .rk-pick-venue {
    font-size: 1rem;
    font-weight: 600;
    color: #FFF8F0;
    transition: color 0.2s;
  }

  .rk-pick:hover .rk-pick-venue {
    color: var(--rk-accent);
  }

  .rk-pick-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .rk-picks {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .rk-picks {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Includes ── */
  .rk-includes {
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 45, 85, 0.15);
    background: rgba(255, 45, 85, 0.04);
    padding: 1.25rem;
  }

  .rk-includes-title {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.025em;
    color: var(--rk-accent);
    margin: 0 0 0.75rem;
  }

  .rk-includes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .rk-includes-list li {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .rk-ok {
    color: var(--rk-ok);
  }

  /* ── Tables ── */
  .rk-tables {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .rk-table-block .rk-h2 {
    margin-bottom: 0.75rem;
  }

  .rk-swipe-tip {
    display: none;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0 0.5rem;
  }

  @media (max-width: 767px) {
    .rk-swipe-tip {
      display: block;
    }
  }

  .rk-scroll {
