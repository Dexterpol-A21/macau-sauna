---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroGallery from '../components/home/HeroGallery.astro';
import AllSaunas from '../components/home/AllSaunas.astro';
import SpinWheel from '../components/smart-match/SpinWheel';
import WhyChooseUsBento from '../components/home/WhyChooseUsBento.astro';
import Testimonials from '../components/home/Testimonials';
import HowItWorks from '../components/home/HowItWorks.astro';
import SlotExtras from '../components/home/SlotExtras.astro';
import Contact from '../components/home/Contact.astro';
import { SITE_DESCRIPTION, SEO_KEYWORDS } from '../utils/constants';
import { TITLE_HOME } from '../utils/seo-titles';
---

<!-- Preload LCP image for mobile -->
<link rel="preload" as="image" href="/images/venues/sauna1/manhaospa.webp" fetchpriority="high" media="(max-width: 767px)" />

<BaseLayout
  seo={{
    title: TITLE_HOME,
    description: SITE_DESCRIPTION,
    keywords: SEO_KEYWORDS,
  }}
>
  <HeroGallery />

  <AllSaunas />

  <HowItWorks />

  <SpinWheel client:load />

  <WhyChooseUsBento />

  <SlotExtras />

  <Testimonials client:load />

  <Contact />
</BaseLayout>
