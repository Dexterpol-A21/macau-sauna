---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FEATURED_VENUES } from '../utils/parseVenues';
import { SEO_KEYWORDS } from '../utils/constants';
import { TITLE_HOW_IT_WORKS } from '../utils/seo-titles';
import Testimonials from '../components/home/Testimonials.astro';
import type { Venue } from '../types';

const WA =
  'https://wa.me/85365670348?text=' +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");
const TG =
  'https://t.me/Aomensauna?text=' +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");

const CHANNELS = [
  { name: 'WhatsApp', detail: 'Message us', href: WA, icon: '/whatsapp.svg', external: true },
  { name: 'Telegram', detail: '@Aomensauna', href: TG, icon: '/telegram.svg', external: true },
  { name: 'WeChat', detail: 'AN99348', href: '/contact', icon: '/wechat.svg', external: false },
  { name: 'LINE', detail: '16880348', href: 'https://line.me/ti/p/VZHFDSZnq9', icon: '/line.svg', external: true },
];

const RECOMMENDATIONS: { want: string; slug: string; reason: string }[] = [
  { want: 'First time', slug: 'number-one-sauna', reason: 'The largest therapist roster in all of Macau, widest selection spanning 8 nationalities. The selection show is spectacular, processes are mature and reliable — least likely to have a bad experience, making it the safest choice for newcomers.' },
  { want: 'Best value', slug: 'familia-nobre', reason: 'Zero service fee — the listed price is the final price with no hidden charges. Largest venue in Macau with ample rooms so you rarely wait, and the food quality has an excellent reputation in the industry.' },
  { want: 'Luxury', slug: 'majesty-spa', reason: 'Over 100 million MOP in renovations, largest rooms in Macau with private bathtubs. No service charge at all, open 24 hours with a comfortable recliner lounge and paid private rest rooms in peak season — one of the most comfortable overnight options.' },
  { want: 'Themed rooms', slug: 'east-castle-spa', reason: 'The pioneer of themed rooms in Macau with 20+ meticulously designed scenes including prison, classroom, and airplane cabin. Staff are trained in professional roleplay — fully customizable scripts and interactions.' },
  { want: 'Taipa area', slug: 'oceanic-royal-spa', reason: 'The only sauna in Taipa/Cotai, next to The Venetian and MGM Cotai — no need to cross the bridge if staying in the area. Highest proportion of Japanese and Korean therapists in Macau, with dual-service surcharge of only 20-30%, far below industry standard.' },
  { want: '24-hour access', slug: 'the-excellent-sauna', reason: 'The only venue in Macau with therapists on duty 24 hours, no time restrictions. Offers both waterbed services and themed rooms (office, classroom, hospital, etc.) — the only place where you can try both types of experience.' },
  { want: 'Newest venue', slug: 'number-nine-spa', reason: 'Brand new — opened April 2026 with all-new facilities. Features professional stage-lit selection shows, multiple atmosphere-themed rooms, and offers Balinese and Japanese-style massage. Grand opening promotions make it the most attractively priced.' },
  { want: 'Newest premium luxury', slug: 'empire-sauna', reason: "Opened 15 May 2026 — a brand-new HK$80M luxury build on the Macau peninsula. Themed suites with hotel-grade amenities, Taiwanese-influencer and Japanese-celebrity headlining therapists, and signature waterbed treatment rooms. Macau's most ambitious sauna debut of 2026." },
  { want: 'Largest model showcase', slug: 'manhao-spa', reason: "Opened 1 May 2026 inside the Grandview Hotel on Taipa. Features Macau's largest model showcase — a multi-tiered glass-railed catwalk hall under deep blue neon. Integrated suites combine a hotel-grade bedroom with the venue's signature red waterbed under spotlight." },
  { want: 'Stay near Lisboeta (Cotai)', slug: 'shang-pin-spa', reason: "Located inside Lisboeta Macau in Cotai — zero-step convenience if you're staying in the area. One of Macau's newest venues with an upscale fit-out, plus a free therapist add-on with selected packages." },
  { want: 'Crowd-free', slug: 'victoria-sauna', reason: 'Simple, understated atmosphere with a spacious bathhouse and roomy sauna areas. Best pick if you want a calm, quiet experience without the bustle of the larger venues — service quality stays sharp without the crowd.' },
  { want: 'Themed nights / KTV', slug: 'm-club', reason: 'Futuristic cyberpunk-style decor with a curated set of themed rooms — built for guests who want novelty over scale. KTV-style rooms make it a strong pick for groups looking for a different kind of night.' },
];

const venueMap = new Map<string, Venue>(FEATURED_VENUES.map((v) => [v.slug, v]));

const TIPS = [
  'Arrive after 7 PM for the widest staff selection. Most therapists start their shifts around 1 PM and are all present by 7 PM, which is also when selection shows begin.',
  'Bring earplugs and an eye mask for overnight stays. The rest area is a shared space (except Majesty Spa), and other guests coming and going plus venue music can affect sleep — these two small items dramatically improve overnight comfort.',
  'Pay in MOP cash to save 1-3% on exchange fees. Credit cards and electronic payments incur international exchange surcharges — MOP cash is the most economical payment method. You can exchange at border gates or hotel ATMs.',
  "Travel light — robes and slippers are provided on arrival. Bring your phone, wallet, and ID; everything else stays in your locker for the duration. Most guests come in casual clothes and change into the venue's robe straight away — no dress code, no luggage to carry around.",
  "Ask us about current promotions and staff availability before you go. Spas run periodic promotions, and therapist attendance varies daily. Checking in advance avoids arriving only to find your preferred type of therapist isn't available.",
  "Tell us your preferred language up front. We'll match you with a venue and a therapist comfortable in English (or Mandarin, Cantonese, Japanese, or Korean depending on the day). Communicating clearly with your therapist makes a noticeable difference — and saves a lot of guesswork for first-timers.",
  "Coming just for the day? The 24-hour locker storage means you can arrive, sauna, and head back without ever checking into a hotel. Same for guests who've already checked out — drop your luggage safely and enjoy the venue right up to your departure.",
];

const STEPS = [
  { title: 'Contact Us', desc: "Tell us your preferences (venue style, budget range, therapist type), and we'll recommend the best venue based on your needs. We know each venue's specialties and latest updates, so we can make the most accurate match for you." },
  { title: 'Free Pickup', desc: 'Once the venue is confirmed, we arrange a 7-seater private car (Alphard/Mercedes) to pick you up at your designated location — any hotel or spot in Macau. Completely free, no need to hail a taxi or navigate on your own.' },
  { title: 'Arrive & Check In', desc: 'Skip the front-desk queue — partner staff has you priority-checked in on arrival. Pick up your wristband and locker key, then head to the changing room to put on a robe and store your luggage. All venues provide free secure lockers — no need to worry about your belongings.' },
  { title: 'Bathe & Relax', desc: "Spend 20-30 minutes enjoying the jacuzzi, dry sauna, and steam room to let your body unwind. This is an important step to get into the right mindset and is part of the experience — don't rush, take your time." },
  { title: 'Free Dining', desc: 'All venues offer unlimited free dining — premium steak, fresh seafood, slow-simmered Cantonese soups, Sichuan-style stir-fries, fried rice, noodles, fresh fruit, cold beer, and a full drinks list. Available throughout your stay at no extra charge. Some venues are particularly famous for their signature steak, seafood platters, and slow-cooked soups — well worth lingering over.' },
  { title: 'Selection Show', desc: 'This is the highlight — therapists parade through the main hall for you to view up close before making your choice. Each venue has its own style: Number One Sauna features multinational grand parades and Oceanic Royal Spa has stage performances. Shows typically start after 7 PM when the atmosphere peaks.' },
  { title: '60-Minute Service', desc: 'After choosing your therapist, you enter a private room for a 60-minute one-on-one session. Services vary by venue and therapist type, and may include massage, waterbed experiences, or themed room role-play. Everything takes place in a private setting.' },
  { title: 'Rest & Stay Overnight', desc: 'No need to rush out after your session. All venues have rest areas with recliners where you can relax or stay overnight for free (12-15 hours). Continue enjoying free dining and bathing facilities in comfort until the next day. Your complimentary VIP Extras booked through us (back rubbing, head massage, reflexology, manicure, ear cleaning, etc.) are typically scheduled during this rest window — making the overnight even fuller. For the best overnight experience, we recommend Majesty Spa — open 24 hours with a comfortable recliner lounge, plus paid private rest rooms in peak season.' },
  { title: 'Breakfast & Depart', desc: "The next morning, enjoy a free breakfast, shower and freshen up, then leave at your leisure. The entire experience from entry to departure can last up to 15 hours — equivalent to saving one night's hotel cost (MOP 1,000-3,000), while enjoying dining, bathing, service, and rest." },
  { title: 'Free Return — Anywhere in Macau', desc: "Just text us when you're ready to leave — after your meal, right after your service, anytime. We'll send the same private car to take you back to your hotel, the airport, the ferry terminal, or anywhere in Macau. Door-to-door, same zero cost as the pickup — no taxi-hunting, no working out the route." },
];
---

<BaseLayout
  seo={{
    title: TITLE_HOW_IT_WORKS,
    description: 'First time at a Macau sauna? We handle everything — free shuttle, VIP entry, venue recommendation, exclusive pricing, and 24/7 English support. 10-step guide for first-timers.',
    keywords: `Macau sauna guide, how to visit Macau sauna, Macau sauna first time, Macau spa guide, Macau sauna tips, Macau sauna process, Macau sauna steps, ${SEO_KEYWORDS}`,
  }}
>
  <!-- Hero (reference layout) -->
  <section class="chrome-pad relative flex min-h-[45vh] items-start justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-[#0a0a0a]/90 to-[#0a0a0a]"></div>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at top, rgba(255,45,85,0.08), transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 pb-12 text-center">
      <h1 class="fade-up mb-4 text-3xl font-bold tracking-wider sm:text-4xl md:text-5xl">
        First Time at a Macau Sauna?
      </h1>
      <p class="fade-up mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-white/60" style="--fade-delay: 0.08s">
        We'll take care of everything — from transport to venue recommendation
      </p>
      <div class="fade-up flex flex-col items-center justify-center gap-4 sm:flex-row" style="--fade-delay: 0.14s">
        <a
          href="#contact"
          class="rounded-full bg-primary px-8 py-3.5 font-semibold tracking-wider text-[#0a0a0a] transition-all duration-300 hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/20"
        >
          Request Now
        </a>
        <a
          href="/"
          class="flex items-center gap-2 px-6 py-3 text-white/50 transition-colors duration-300 hover:text-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7" /><path d="M19 12H5" /></svg>
          Back to Home
        </a>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="px-4 pb-12 sm:pb-16 sm:pt-2">
    <div class="mx-auto max-w-4xl">
      <div class="fade-up mb-8 text-center">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">What to Expect</h2>
        <div class="mx-auto h-0.5 w-16 bg-primary" aria-hidden="true"></div>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="fade-up rounded-xl border border-white/5 bg-[#141414] p-6 transition-all duration-300 hover:border-primary/20" style="--fade-delay: 0.05s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-primary/20 bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold">Safe &amp; Legal</h3>
          <p class="text-sm leading-relaxed text-white/50">
            All legitimate venues hold a "Steam Bath and Massage Establishment License" issued by the Macao Government Tourism Office, regulated under the same government framework as casinos. Spas undergo regular joint inspections by the Health Bureau, Fire Services, and Tourism Office to ensure hygiene and fire safety compliance. You can verify any venue's license status on the Tourism Office website — fully transparent.
          </p>
          <a
            href="https://www.dst.gov.mo/en/public-services/licensed-entities.html?comType=10&ps=20&pn=1"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 rounded-full border border-primary/40 bg-primary/15 px-4 py-2 text-sm font-semibold text-primary transition-all hover:border-primary/60 hover:bg-primary/25"
          >
            Verify on MGTO website <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="fade-up rounded-xl border border-white/5 bg-[#141414] p-6 transition-all duration-300 hover:border-primary/20" style="--fade-delay: 0.1s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-primary/20 bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" /><path d="M20 2v4" /><path d="M22 4h-4" /><circle cx="4" cy="20" r="2" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold">All-in-One Experience</h3>
          <p class="text-sm leading-relaxed text-white/50">
            From the moment you step in, everything is included: the bathing area features jacuzzis, dry and wet saunas; the dining area offers unlimited free steak, fresh seafood, slow-simmered Cantonese soups, Sichuan-style stir-fries, fried rice, fresh fruit, and cold beer; the entertainment area hosts selection shows and interactive segments; the rest area has recliners for overnight stays. The entire experience can last 12-15 hours — one venue covers all your needs.
          </p>
        </div>

        <div class="fade-up rounded-xl border border-white/5 bg-[#141414] p-6 transition-all duration-300 hover:border-primary/20" style="--fade-delay: 0.15s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-primary/20 bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><path d="M16 3.128a4 4 0 0 1 0 7.744" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><circle cx="9" cy="7" r="4" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold">We Handle Everything</h3>
          <p class="text-sm leading-relaxed text-white/50">
            You don't need to research, compare, or arrange anything yourself. Tell us your preferences and budget, and we'll recommend the best venue, arrange free private car pickup (anywhere in Macau), negotiate exclusive pricing for you, and inform you of therapist availability and wait times in advance. Walking in alone may mean 1-2 hour waits and higher prices — booking through us avoids all of that.
          </p>
        </div>

        <div class="fade-up rounded-xl border border-white/5 bg-[#141414] p-6 transition-all duration-300 hover:border-primary/20" style="--fade-delay: 0.2s">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-primary/20 bg-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary" aria-hidden="true"><path d="M12 7v14" /><path d="M20 11v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8" /><path d="M7.5 7a1 1 0 0 1 0-5A4.8 8 0 0 1 12 7a4.8 8 0 0 1 4.5-5 1 1 0 0 1 0 5" /><rect x="3" y="7" width="18" height="4" rx="1" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold">VIP Extras</h3>
          <p class="text-sm leading-relaxed text-white/50">
            Every booking through us includes 1 complimentary VIP Extra — pick from Back Rubbing, head massage, reflexology, manicure, pedicure, hand massage, ear cleaning, and more. We let the venue know you're coming — simply pick what you want on arrival. Plus priority entry — no front-desk wait.
          </p>
          <button
            type="button"
            data-open-vip-extras
            class="mt-4 inline-flex cursor-pointer items-center gap-1.5 rounded-full border border-primary/40 bg-primary/15 px-4 py-2 text-sm font-semibold text-primary shadow-[0_0_16px_rgba(255,45,85,0.18)] transition-all hover:border-primary/60 hover:bg-primary/25 hover:shadow-[0_0_22px_rgba(255,45,85,0.32)]"
          >
            See all 8 →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Ranking CTA strip -->
  <section class="px-4 pb-4">
    <div class="mx-auto max-w-4xl">
      <a
        href="/ranking"
        class="fade-up group flex flex-col justify-between gap-3 rounded-xl border border-primary/15 bg-[#141414] p-5 transition-all duration-300 hover:border-primary/40 sm:flex-row sm:items-center"
      >
        <p class="text-sm leading-relaxed text-white/65">
          Want the full ranking of all 12 venues — price, overnight, KTV, and the free massages included with every booking?
        </p>
        <span class="inline-flex items-center gap-1.5 whitespace-nowrap text-sm font-semibold text-primary transition-colors group-hover:text-primary-light">
          See the Macau sauna ranking
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- Step-by-Step -->
  <section class="bg-gradient-to-b from-[#0a0a0a] via-[#0f0f0f] to-[#0a0a0a] px-4 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      <div class="fade-up mb-8 text-center">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">Step-by-Step Process</h2>
        <div class="mx-auto mb-4 h-0.5 w-16 bg-primary" aria-hidden="true"></div>
        <p class="mx-auto max-w-xl text-sm italic text-white/40">Each venue may differ slightly. Contact us for details.</p>
      </div>

      <div class="relative mx-auto max-w-2xl">
        <div class="absolute bottom-2 left-5 top-2 w-px bg-primary/20" aria-hidden="true"></div>
        <div class="space-y-6">
          {STEPS.map((step, i) => (
            <div
              class="fade-up relative flex items-start gap-5"
              style={`--fade-delay: ${(0.04 + i * 0.06).toFixed(2)}s`}
            >
              <div class="relative z-10 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border border-primary/30 bg-primary/15">
                <span class="text-sm font-bold text-primary">{i + 1}</span>
              </div>
              <div class="pb-2 pt-1.5">
                <h3 class="mb-1 text-base font-semibold">{step.title}</h3>
                <p class="text-sm leading-relaxed text-white/50">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Ask us strip -->
  <section class="px-4 pb-8 pt-4">
    <div class="fade-up mx-auto max-w-4xl text-center">
      <p class="mb-3 text-sm text-white/50">Don't want to read? Just ask us directly</p>
      <div class="flex items-center justify-center gap-3">
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-lg border border-white/10 bg-[#141414] px-3 py-2 transition-colors hover:border-primary/30"
        >
          <img src="/whatsapp.svg" alt="" class="h-5 w-5 rounded-md" width="20" height="20" />
          <span class="text-sm text-white/70">WhatsApp</span>
        </a>
        <a
          href="https://t.me/Aomensauna"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-lg border border-white/10 bg-[#141414] px-3 py-2 transition-colors hover:border-primary/30"
        >
          <img src="/telegram.svg" alt="" class="h-5 w-5 rounded-md" width="20" height="20" />
          <span class="text-sm text-white/70">Telegram</span>
        </a>
        <a href="#contact" class="text-sm text-primary transition-colors hover:text-primary-light">
          All contacts →
        </a>
      </div>
    </div>
  </section>

  <!-- Sauna Recommendations -->
  <section class="px-4 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      <div class="fade-up mb-8 text-center">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">Sauna Recommendations</h2>
        <div class="mx-auto h-0.5 w-16 bg-primary" aria-hidden="true"></div>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {RECOMMENDATIONS.map((rec, i) => {
          const v = venueMap.get(rec.slug);
          if (!v) return null;
          return (
            <a
              href={`/venues/${v.slug}`}
              class="fade-up group block rounded-xl border border-white/5 bg-[#141414] p-2.5 transition-all duration-300 hover:border-primary/30"
              style={`--fade-delay: ${(0.04 + i * 0.05).toFixed(2)}s`}
            >
              <div class="mb-2 text-xs text-white/40">
                I want: <span class="text-primary/80">{rec.want}</span>
              </div>
              <div class="mb-1.5 flex items-center justify-between">
                <h3 class="text-base font-semibold transition-colors group-hover:text-primary">{v.name}</h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/20 transition-colors group-hover:text-primary/60" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
              </div>
              <p class="text-sm text-white/50">{rec.reason}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Insider Tips -->
  <section class="bg-gradient-to-b from-[#0a0a0a] via-[#0f0f0f] to-[#0a0a0a] px-4 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      <div class="fade-up mb-8 text-center">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">Insider Tips</h2>
        <div class="mx-auto h-0.5 w-16 bg-primary" aria-hidden="true"></div>
      </div>
      <div class="mx-auto max-w-2xl space-y-4">
        {TIPS.map((tip, i) => (
          <div
            class="fade-up flex items-start gap-4 rounded-xl border border-white/5 bg-[#141414] p-4"
            style={`--fade-delay: ${(0.04 + i * 0.05).toFixed(2)}s`}
          >
            <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg border border-primary/20 bg-primary/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-primary" aria-hidden="true"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" /><path d="M9 18h6" /><path d="M10 22h4" /></svg>
            </div>
            <p class="pt-1 text-sm leading-relaxed text-white/70">{tip}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- Still Have Questions -->
  <section id="contact" class="scroll-mt-6 px-4 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl">
      <div class="fade-up mb-8 text-center">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">Still Have Questions?</h2>
        <div class="mx-auto mb-6 h-0.5 w-16 bg-primary" aria-hidden="true"></div>
        <p class="mx-auto mb-6 max-w-xl text-white/50">
          We'll answer everything and arrange the best experience for you
        </p>
        <a
          href="/faq"
          class="inline-flex items-center gap-2 rounded-full border border-primary/50 px-6 py-3 text-sm tracking-wider text-primary transition-all duration-300 hover:bg-primary/10"
        >
          View FAQ
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
        </a>
      </div>

      <div class="mx-auto mt-10 grid max-w-md grid-cols-1 gap-4 sm:grid-cols-2">
        {CHANNELS.map((ch, i) => (
          <a
            href={ch.href}
            class="fade-up group flex w-full items-center gap-4 rounded-xl border border-white/5 bg-[#141414] p-2.5 text-left transition-all duration-300 hover:border-primary/30"
            style={`--fade-delay: ${(0.05 + i * 0.06).toFixed(2)}s`}
            {...(ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 transition-colors group-hover:bg-primary/20">
              <img src={ch.icon} alt="" class="h-7 w-7 rounded-md" width="28" height="28" />
            </div>
            <div>
              <div class="mb-1 text-xs text-white/40">{ch.name}</div>
              <div class="font-medium text-white">{ch.detail}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
