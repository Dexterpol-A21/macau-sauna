---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../utils/constants';
import { TITLE_PRIVACY } from '../utils/seo-titles';
---

<BaseLayout
  seo={{
    title: TITLE_PRIVACY,
    description: `We do not collect, store or keep any personal information. Privacy policy for ${SITE_TITLE}.`,
    keywords: '',
    noindex: true,
  }}
>
  <section class="chrome-pad px-4 pb-16">
    <div class="mx-auto max-w-3xl">
      <a
        href="/"
        class="group mb-6 inline-flex items-center text-sm text-white/40 transition-colors hover:text-primary"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mr-2 transition-transform group-hover:-translate-x-1"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Back to home
      </a>

      <h1 class="mb-3 text-3xl font-bold sm:text-4xl">Privacy Policy</h1>
      <p class="mb-8 text-sm text-white/40">Effective date: 2026-06-14</p>

      <div
        class="mb-10 rounded-2xl border border-primary/15 bg-gradient-to-b from-primary/[0.06] to-transparent p-5 sm:p-6"
      >
        <p class="leading-relaxed text-white/80">
          {SITE_TITLE} ("we", "us") takes your privacy seriously. In short: we do
          not collect, store or keep any personal information. This policy explains how we treat your
          information.
        </p>
      </div>

      <div class="mb-8">
        <h2 class="mb-3 text-xl font-bold text-primary">Our approach to your data</h2>
        <p class="mb-3 leading-relaxed text-white/65">
          Your conversation stays inside whichever messaging app you choose (WhatsApp, WeChat, Line,
          Telegram), not with us.
        </p>
        <p class="mb-3 leading-relaxed text-white/65">
          The details you provide (such as time and party size) are used only to complete that one
          booking, and nothing more.
        </p>
      </div>

      <div class="mb-8">
        <h2 class="mb-3 text-xl font-bold text-primary">What we never ask for</h2>
        <p class="mb-3 leading-relaxed text-white/65">
          We never ask for ID numbers or credit card details. All fees are paid directly on site.
        </p>
      </div>

      <div class="mb-8">
        <h2 class="mb-3 text-xl font-bold text-primary">Sharing</h2>
        <p class="mb-3 leading-relaxed text-white/65">
          We pass only the minimum a booking needs to the venue you chose, and never sell, rent or trade
          any of your information.
        </p>
        <p class="mb-3 leading-relaxed text-white/65">
          This site uses only anonymous, aggregated analytics; any update to this policy is posted here
          with a revised date.
        </p>
      </div>

      <div class="mt-10 border-t border-white/5 pt-6">
        <a
          href="/contact"
          class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
        >
          Questions about your privacy? Contact us →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
