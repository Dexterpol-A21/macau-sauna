export function getStaticPaths() {
  return FEATURED_VENUES.map((v) => ({
    params: { slug: v.slug },
  }));
}

const { slug } = Astro.params;
const venue = FEATURED_VENUES.find((v) => v.slug === slug) as Venue;

if (!venue) {
  return Astro.redirect('/404');
}

