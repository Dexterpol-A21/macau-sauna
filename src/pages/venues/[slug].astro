  'the-excellent-sauna': [
    { num: 1, title: 'Arrive & Check In', description: "Arrive at The Excellent Sauna inside the Grand Emperor Hotel main building — the venue is open 24 hours with dining served 24 hours, and therapists work 1:00 PM – 5:00 AM. Whether it's the middle of the night, early morning, or afternoon, you can walk in anytime to rest." },
