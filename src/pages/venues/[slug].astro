  'oceanic-royal-spa': [
    { num: 1, title: 'Arrive & Check In', description: 'Arrive at Oceanic Royal Spa in Taipa, conveniently located near The Venetian and MGM Cotai — the most popular spa venue in the Taipa/Cotai area. Register at the front desk, collect your wristband, and change into a robe.' },
    { num: 2, title: 'Bathe & Relax', description: "Enjoy the clean, comfortable bathing facilities and sauna. Oceanic Royal's rest-area massage therapists are also quite skilled — the standalone massage service is worth trying on its own." },
    { num: 3, title: 'Free Dining', description: 'Complimentary dining included. From 5 to 8 PM, Oceanic Royal serves a free seafood buffet — shrimp, crab, shellfish, salmon sashimi, and geoduck — a dining highlight unique to Oceanic Royal.' },
    { num: 4, title: 'Stage Selection Show', description: "In the evening, scheduled selection shows have staff step onto the central stage one by one, fashion-show style. Oceanic Royal's shows are more brisk and refined compared to Number One's larger-scale format. Its Japanese and Korean lineup is strong, on par with Number Nine among Macau's top venues. During daytime, the manager arranges a face-to-face lineup instead." },
    { num: 5, title: 'Choose Your Therapist', description: "Tell the manager your pick and confirm the service tier and price. Oceanic Royal has one of Macau's strongest Japanese and Korean lineups, on par with Number Nine — a top choice for those seeking that experience. Note that Oceanic Royal charges a 10% service fee." },
    { num: 6, title: '60-Minute Session', description: 'Enter a private room for a one-on-one session. Oceanic Royal also offers a dual-therapist option for guests who want a fuller lineup experience.' },
    { num: 7, title: 'Rest & Stay Overnight', description: "Stay overnight using the reclining chairs in the free lounge area. Oceanic Royal's convenient Taipa location means guests staying at Cotai hotels can reach it without crossing to the peninsula — just head back to your hotel when you're done." },
  ],
  'number-one-sauna': [
    { num: 1, title: 'Arrive & Check In', description: 'Arrive at Number One Sauna and register at the front desk to collect your wristband and locker key. The changing rooms are spacious with brand-new facilities.' },
    { num: 2, title: 'Bathe & Relax', description: 'The venue features a large jacuzzi, dry sauna, and steam room with soft, ambient lighting. We recommend spending 20–30 minutes soaking first to unwind and ease into the experience.' },
    { num: 3, title: 'Free Dining', description: "Unlimited complimentary food throughout your stay — the signature steak is Number One's most popular dish, alongside fried rice, fried noodles, fresh fruit platters, and cold beer. The spacious dining area overlooks the main hall activity." },
    { num: 4, title: 'Grand Selection Show', description: 'Each night, 130+ staff walk the hall runway in groups with professional lighting and sound — a spectacular sight. Each round takes about 30 minutes, featuring staff from China, Vietnam, Thailand, Taiwan, Japan, Korea, Russia, and Ukraine — the largest and most international show in all of Macau.' },
    { num: 5, title: 'Choose Your Therapist', description: 'Tell the manager your preferred number and they\'ll confirm the service tier and corresponding price. Prices range from MOP 2,199 to MOP 7,699 depending on the staff category. During peak hours (22:00–00:00 on weekends), popular therapists may require a wait — arriving early is recommended.' },
    { num: 6, title: '60-Minute Session', description: 'Enter a private room for an exclusive one-on-one water bed session — Number One is famous across Macau for its water bed service. You can add a dual service with a second therapist for an additional fee. Additional paid mini-services include ear cleaning, nail care, and back massage.' },
    { num: 7, title: 'Rest & Stay Overnight', description: 'After your session, rest in reclining chairs or stay overnight. Note that the rest area gets lively during peak hours; for quiet sleep, aim to settle in after 2 AM, with 6–8 AM being the quietest. Enjoy a complimentary breakfast the next morning before heading out.' },
  ],
  'familia-nobre': [
    { num: 1, title: 'Arrive & Check In', description: 'Arrive at Familia Nobre and register at the front desk to collect your wristband and locker key. The changing room has secure lockers for free luggage storage — slip into a robe and you\'re ready to go.' },
    { num: 2, title: 'Bathe & Relax', description: 'The bathing area is the largest in all of Macau, with multiple jacuzzis and sauna rooms in a spacious, uncrowded setting. Even during peak hours, you won\'t find yourself waiting in line.' },
    { num: 3, title: 'Free Dining', description: "Complimentary steak, cold beer, and various stir-fry dishes — Familia Nobre's steak and beer are highly praised among regulars. The dining area is spacious and comfortable, with unlimited servings at no extra charge." },
    { num: 4, title: 'Selection', description: 'The manager lines up a row of therapists for you to observe up close and choose at your own pace. Price tiers for each group are announced in advance so you know the cost before selecting.' },
    { num: 5, title: 'Choose Your Therapist', description: 'Zero service fee — the listed price is the final price with no hidden charges or surcharges. Prices range from MOP 2,388 to MOP 6,988, making it the best value in Macau. With ample space and rooms, there\'s virtually no waiting.' },
    { num: 6, title: '60-Minute Session', description: 'Enter a private room for an exclusive one-on-one session. Familia Nobre has the most rooms of any venue in Macau, so even during busy periods you\'ll rarely have to wait — a smooth and seamless experience.' },
    { num: 7, title: 'Rest & Stay Overnight', description: 'The most reclining chairs of any venue in a spacious rest area with generous spacing between seats for comfortable overnight stays. No noisy entertainment shows to disturb you — ideal for quiet rest. Enjoy a complimentary breakfast the next morning before leaving.' },
  ],
};

const flowSteps = FLOW_STEPS_MAP[slug] ?? [];

// Split fullDescription into paragraphs and footer
const descParts = venue.fullDescription ? venue.fullDescription.split('|||') : [];
const paragraphs = descParts[0]?.split('||') ?? [];
const footerNote = descParts[1] ?? '';

// ── SEO helpers ──
const seoTitle = titleVenueDetail(venue.name);
const seoDescription = (() => {
  // Use first paragraph of fullDescription, trimmed to ~160 chars
  if (paragraphs[0]) {
    const t = paragraphs[0].replace(/<[^>]+>/g, '').trim();
    if (t.length > 160) return t.slice(0, 157) + '...';
    return t;
  }
  return venue.description;
})();
const seoKeywords = `${venue.name.toLowerCase()}, ${venue.name.toLowerCase()} Macau, ${venue.name.toLowerCase()} Macao, Macau sauna ${venue.name.toLowerCase()}, Macau spa ${venue.name.toLowerCase()}, ${venue.name.toLowerCase()} prices, ${venue.name.toLowerCase()} booking, ${venue.name.toLowerCase()} ${venue.location?.split(',')[0]?.trim() || 'Macau'}, ${SEO_KEYWORDS}`;

// ── Structured Data: LocalBusiness ──
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: venue.name,
  description: venue.description,
  image: heroImage,
  url: `${Astro.site || 'https://macausauna.com'}/venues/${venue.slug}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: venue.location?.includes(',') ? venue.location.split(',')[0].trim() : "Macau",
    addressCountry: "MO",
  },
  ...(venue.priceRange && { priceRange: venue.priceRange }),
  ...(venue.hours && { openingHours: venue.hours }),
  ...(venue.rating && { aggregateRating: { "@type": "AggregateRating", ratingValue: venue.rating, bestRating: "5" } }),
});
---

<BaseLayout
  seo={{
    title: seoTitle,
    description: seoDescription,
    keywords: seoKeywords,
    image: heroImage,
  }}
>
  <!-- Venue LocalBusiness JSON-LD -->
  <script type="application/ld+json" set:html={localBusinessSchema}></script>
  <main class="vd-page">
    <!-- Parallax Hero -->
    <VenueParallaxHero venue={venue} accent={accent} tags={tags} imageFolder={imageFolder} heroImage={heroImage} imageBase={imageConfig?.base ?? ''} client:load />

    <!-- Venue Name -->
    <section class="vd-name-block">
      <div class="vd-tags">
        {tags.map((t) => (
          <span
            class="vd-tag"
            style={t.primary
              ? `background-color: ${t.color}; color: #0A0A0A;`
              : `color: ${t.color}; background: transparent; border: 1px solid ${t.color}33;`}
          >
            {t.label}
          </span>
        ))}
      </div>
      <h1 class="vd-name-big">
        <SlotMachineText text={venue.name} stripLength={10} client:visible />
      </h1>
      <p class="vd-subtitle">{venue.subtitle}</p>
      <div class="vd-location">
        <svg class="vd-location-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        {venue.location}
      </div>
    </section>

    <!-- Body Section -->
    {venue.fullDescription && (
      <section class="vd-body-section">
        <div class="vd-body-wrap">

          {/* Full Description */}
          {paragraphs.map((p) => (
            <p class="vd-desc-full">{p}</p>
          ))}
          {footerNote && (
            <div class="vd-footer-row">
              <p class="vd-desc-footer">{footerNote}</p>
              {venue.website && (
                <span class="vd-footer-site">
                  <a href={`https://${venue.website}`} target="_blank" rel="noopener noreferrer" class="vd-details-website">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <line x1="2" y1="12" x2="22" y2="12" />
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                    {venue.website}
                  </a>
                  <span class="vd-stars-inline">
                    {Array.from({ length: 5 }).map(() => (
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="#FF4DA6" stroke="none">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                      </svg>
                    ))}
                  </span>
                </span>
              )}
            </div>
          )}
          {!footerNote && venue.website && (
            <div class="vd-footer-row">
              <span class="vd-footer-site">
                <a href={`https://${venue.website}`} target="_blank" rel="noopener noreferrer" class="vd-details-website">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="2" y1="12" x2="22" y2="12" />
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  </svg>
                  {venue.website}
                </a>
                <span class="vd-stars-inline">
                  {Array.from({ length: 5 }).map(() => (
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="#FF4DA6" stroke="none">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </span>
              </span>
            </div>
          )}

          {/* Info Cards Grid */}
          {venue.referencePrice && (<>
            <div class="vd-card-grid">

              {/* Reference Price */}
              <div class="vd-card">
                <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
                <span class="vd-card-label">Reference Price</span>
                <span class="vd-card-value vd-card-price">{venue.referencePrice}</span>
                <a href="/#contact" class="vd-card-link">Contact us for a discount</a>
              </div>

              {/* Staff */}
              {venue.staffNationalities && (
                <div class="vd-card">
                  <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                  <span class="vd-card-label">Staff</span>
                  <span class="vd-card-value">Multinational</span>
                  <span class="vd-card-sub">{venue.staffNationalities}</span>
                </div>
              )}

              {/* Hours */}
              <div class="vd-card">
                <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
                <span class="vd-card-label">Hours</span>
                <span class="vd-card-value">{venue.hours}</span>
                {venue.staffHours && (
                  <span class="vd-card-sub">{venue.staffHours}</span>
                )}
              </div>

              {/* Overnight */}
              {venue.overnight && (() => {
                const overnightUnavailable = venue.overnight.toLowerCase().includes('not available');
                return (
                  <div class={`vd-card ${overnightUnavailable ? 'vd-card-overnight-red' : 'vd-card-overnight-green'}`}>
                    <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                    <span class="vd-card-label">Overnight</span>
                    <span class="vd-card-value vd-card-overnight">{venue.overnight}</span>
                  </div>
                );
              })()}

              {/* Best For */}
              {venue.bestFor && (
                <div class="vd-card">
                  <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <circle cx="12" cy="12" r="6" />
                    <circle cx="12" cy="12" r="2" />
                  </svg>
                  <span class="vd-card-label">Best For</span>
                  <span class="vd-card-value">{venue.bestFor}</span>
                </div>
              )}

              {/* Payment */}
              {venue.payment && (
                <div class="vd-card">
                  <svg class="vd-card-bg-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                    <line x1="1" y1="10" x2="23" y2="10" />
                  </svg>
                  <span class="vd-card-label">Payment</span>
                  <div class="vd-payment-list">
                    {venue.payment.map((p) => (
                      <span class="vd-payment-badge">{p}</span>
                    ))}
                  </div>
                </div>
              )}

            </div>

            {/* Highlights */}
            {venue.highlights && (
              <div class="vd-hl-row">
                {venue.highlights.map((h, i) => (
                  <div class={`vd-hl-tile ${i === 0 ? 'vd-hl-tile-accent' : ''}`}>
                    <span class="vd-hl-tile-text">{h}</span>
                  </div>
                ))}
              </div>
            )}
          </>)}

          {/* Contact CTA */}
          <div class="vd-contact-cta">
            <ContactCTA client:load />
          </div>

        </div>
      </section>
    )}

    {/* Gallery */}
    {imageFolder && galleryItems.length > 0 && (
      <section class="vd-gallery-section">
        <div class="vd-gallery-wrap">
          <h2 class="vd-gallery-title">
            <SlotMachineText text="Gallery" stripLength={6} client:visible />
          </h2>
          <VenueGallery items={galleryItems} client:load />
        </div>
      </section>
    )}

    {/* Detailed Flow */}
    {flowSteps.length > 0 && (
      <section class="vd-flow-section">
        <div class="vd-flow-wrap">
          <h2 class="vd-flow-title">
            <SlotMachineText text="Detailed Flow" stripLength={10} client:visible />
          </h2>
          <VenueFlow steps={flowSteps} client:load />
        </div>
      </section>
    )}

    {/* Other Popular Spas */}
    <section class="vd-other-section">
      <div class="vd-other-wrap">
        <h2 class="vd-other-title">
          <SlotMachineText text="Other Popular Spas" stripLength={12} client:visible />
        </h2>
        <div class="vd-other-grid">
          {FEATURED_VENUES
            .filter((v) => v.slug !== venue.slug)
            .slice(0, 3)
            .map((v, i) => (
              <a href={`/venues/${v.slug}`} class={`vd-other-card ${i === 0 ? 'vd-other-card--hero' : ''}`}>
                <div class="vd-other-img-wrap">
                  <img src={v.image} alt={v.name} class="vd-other-img" loading="lazy" />
                </div>
                <div class="vd-other-info">
                  <h4 class="vd-other-name">{v.name}</h4>
                  <p class="vd-other-desc">{v.description}</p>
                  <span class="vd-other-link">
                    Learn More
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </span>
                </div>
              </a>
            ))}
        </div>
      </div>
    </section>

    {/* Final CTA */}
    <section class="vd-final-section">
      <div class="vd-final-wrap">
        <span class="vd-final-eyebrow">24/7 Support</span>
        <h2 class="vd-final-title">Let&apos;s Talk</h2>
        <p class="vd-final-message">More than a service. A memory you&rsquo;ll keep.</p>
        <p class="vd-final-body">
          Macau runs on hospitality. Every guest deserves a night that stays with them,
          and we make sure yours is nothing short of <em>unforgettable</em>.
        </p>
        <div class="vd-final-btn">
          <ContactCTA client:load />
        </div>
        <p class="vd-final-note">We reply within minutes, any hour of the day. Your satisfaction is what drives us.</p>
      </div>
    </section>
  </main>
</BaseLayout>

