---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ABOUT_DESCRIPTION, ABOUT_KEYWORDS, SITE_TITLE } from '../utils/constants';
import { TITLE_ABOUT } from '../utils/seo-titles';

const WA =
  'https://wa.me/85365670348?text=' +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");
const TG =
  'https://t.me/Aomensauna?text=' +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");

const CHANNELS = [
  { name: 'WhatsApp', detail: 'Message us', href: WA, icon: '/whatsapp.svg', external: true },
  { name: 'Telegram', detail: '@Aomensauna', href: TG, icon: '/telegram.svg', external: true },
  { name: 'WeChat', detail: 'AN99348', href: '/contact', icon: '/wechat.svg', external: false },
  { name: 'LINE', detail: '16880348', href: 'https://line.me/ti/p/VZHFDSZnq9', icon: '/line.svg', external: true },
];

const DO_ITEMS = [
  {
    title: 'We Curate',
    body: "Macau has many sauna venues. Only 12 meet our quality, safety, and value bar. We'll match you to the right one based on your preferences — language, vibe, price, staff nationality. No guesswork on your end.",
    icon: '<path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/>',
    link: null as { href: string; label: string } | null,
  },
  {
    title: 'We Drive',
    body: "Free luxury vehicle pickup from your hotel, the airport, the ferry terminal — anywhere in Macau or Taipa — plus a complimentary ride back to your hotel when you're done. Same vehicle, same driver, just a text away.",
    icon: '<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>',
    link: { href: '/shuttle', label: 'See our free shuttle service →' },
  },
  {
    title: 'We Add a VIP Extra',
    body: "1 complimentary VIP Extra with every booking — head massage, reflexology, manicure, and more. We let the venue know you're coming — pick on arrival.",
    icon: '<path d="M12 7v14"/><path d="M20 11v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"/><path d="M7.5 7a1 1 0 0 1 0-5A4.8 8 0 0 1 12 7a4.8 8 0 0 1 4.5-5 1 1 0 0 1 0 5"/><rect x="3" y="7" width="18" height="4" rx="1"/>',
    link: null,
  },
  {
    title: 'We Stay With You',
    body: "We don't disappear after you arrive. Need something during your visit? Want a different recommendation? Want help with anything? Text us — same chat, 24/7, until you say you're happy.",
    icon: '<path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/><path d="M20 2v4"/><path d="M22 4h-4"/><circle cx="4" cy="20" r="2"/>',
    link: null,
  },
];

const STATS = [
  {
    num: '1,000+',
    label: 'Guests served',
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="9" cy="7" r="4"/>',
  },
  {
    num: '24/7',
    label: 'Chat support',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  },
  {
    num: 'MGTO',
    label: 'Every venue licensed',
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  },
  {
    num: '12',
    label: 'Curated saunas',
    icon: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>',
  },
];

const jsonLdAbout = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Macau Sauna Booking',
  description: ABOUT_DESCRIPTION,
  about: {
    '@type': 'Organization',
    name: SITE_TITLE,
    url: 'https://macausauna.com',
    logo: 'https://macausauna.com/logo.svg',
    description: ABOUT_DESCRIPTION,
  },
});
---

<BaseLayout
  seo={{
    title: TITLE_ABOUT,
    description: ABOUT_DESCRIPTION,
    keywords: ABOUT_KEYWORDS,
  }}
>
  <script type="application/ld+json" set:html={jsonLdAbout}></script>

  <!-- 0. Hero — max-w-3xl, eyebrow About, h1 with primary span -->
  <section class="chrome-pad px-4 pb-12">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-primary/80">About</p>
      <h1 class="mb-6 text-3xl font-bold leading-tight sm:text-5xl">
        Macau's Concierge for <span class="text-primary">Premium Saunas</span>
      </h1>
      <p class="mx-auto max-w-2xl text-base leading-relaxed text-white/70 sm:text-lg">
        We're the team behind <span class="font-semibold text-primary">Macau Sauna Booking</span> — a
        small concierge crew with members from Taiwan, Hong Kong, and Macau, serving visitors coming to
        a Macau sauna (selection show, private 1-on-1 sessions, themed rooms, 12-hour overnight stays).
        Complimentary transport, exclusive pricing, complimentary VIP Extras, and a real human on chat
        24/7.
      </p>
      <div class="mt-6">
        <a
          href="/"
          class="group inline-flex items-center text-sm text-white/40 transition-colors hover:text-primary"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mr-2 transition-transform group-hover:-translate-x-1"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </section>

  <!-- 1. What we actually do for you -->
  <section class="px-4 py-12">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <h2 class="mb-3 text-2xl font-bold sm:text-3xl">What we actually do for you</h2>
        <div class="mx-auto h-0.5 w-16 bg-primary" aria-hidden="true"></div>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        {
          DO_ITEMS.map((item) => (
            <div class="rounded-2xl border border-white/5 bg-[#141414] p-6 transition-colors hover:border-primary/30 sm:p-7">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-primary/20 bg-primary/10">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6 text-primary"
                  aria-hidden="true"
                  set:html={item.icon}
                />
              </div>
              <h3 class="mb-2 text-lg font-semibold text-white">{item.title}</h3>
              <p class="text-sm leading-relaxed text-white/60">{item.body}</p>
              {item.link && (
                <a
                  href={item.link.href}
                  class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
                >
                  {item.link.label}
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2. Why guests trust us -->
  <section class="px-4 py-12">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center">
        <h2 class="mb-3 text-2xl font-bold sm:text-3xl">Why guests trust us</h2>
        <div class="mx-auto h-0.5 w-16 bg-primary" aria-hidden="true"></div>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
        {
          STATS.map((stat) => (
            <div class="rounded-2xl border border-white/5 bg-[#141414] p-5 text-center sm:p-6">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mx-auto mb-3 h-7 w-7 text-primary"
                aria-hidden="true"
                set:html={stat.icon}
              />
              <p class="mb-1 text-2xl font-bold text-primary sm:text-3xl">{stat.num}</p>
              <p class="text-xs leading-tight text-white/50 sm:text-sm">{stat.label}</p>
            </div>
          ))
        }
      </div>

      <p class="mx-auto mt-6 max-w-xl text-center text-xs leading-relaxed text-white/40 sm:text-sm">
        Every venue we recommend holds a current license from the Macao Government Tourism Office (MGTO)
        and operates under the same regulatory framework as Macau's casinos.
      </p>
    </div>
  </section>

  <!-- 3. The personal why -->
  <section class="px-4 py-12">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-2xl border border-white/5 bg-[#141414] p-8 sm:p-10">
        <h2 class="mb-4 text-2xl font-bold sm:text-3xl">The personal why</h2>
        <div class="space-y-4 text-base leading-relaxed text-white/70">
          <p>
            Most first-time visitors to Macau saunas walk in cold — wrong venue for their preferences, no
            transport arranged, walk-in pricing, no idea what's included, no idea what isn't. They have
            an OK time and they leave a little disappointed.
          </p>
          <p>
            We started Macau Sauna Booking because that was avoidable. With one chat, you get the right
            venue, complimentary transport both ways, the best price, complimentary VIP Extras, and
            someone in your corner if anything feels off. Better experience, lower cost, zero hassle.
          </p>
          <p>Same sauna price (often cheaper), plus the full concierge package. That's it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Ready for your VIP Experience? -->
  <section id="contact" class="scroll-mt-6 px-4 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-3xl font-bold sm:text-4xl">
        Ready for your <span class="text-primary">VIP Experience?</span>
      </h2>
      <p class="mx-auto mb-8 max-w-xl text-white/60">Send us a message and we'll take care of the rest.</p>

      <div class="mx-auto grid max-w-md grid-cols-1 gap-4 sm:grid-cols-2 sm:max-w-none">
        {
          CHANNELS.map((ch) => (
            <a
              href={ch.href}
              class="group flex w-full items-center gap-4 rounded-xl border border-white/5 bg-[#141414] p-2.5 text-left transition-all duration-300 hover:border-primary/30"
              {...(ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 transition-colors group-hover:bg-primary/20">
                <img src={ch.icon} alt="" class="h-7 w-7 rounded-md" width="28" height="28" />
              </div>
              <div>
                <div class="mb-1 text-xs text-white/40">{ch.name}</div>
                <div class="font-medium text-white">{ch.detail}</div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. Mission strip -->
  <section class="px-4 pb-12 sm:pb-16">
    <div class="mx-auto max-w-3xl">
      <div
        class="rounded-2xl border border-primary/25 bg-gradient-to-b from-primary/10 to-primary/5 px-6 py-7 sm:px-8 sm:py-9"
        data-testid="mission-section"
      >
        <p class="mx-auto max-w-2xl whitespace-pre-line text-left text-sm leading-relaxed text-white/85 sm:text-base">
          Macau lives on hospitality. Every guest deserves a night they'll remember — not just "fine,"
          but unforgettable. We do all of this so your sauna experience becomes one of the best memories
          you take home from Macau.
        </p>
        <p class="mt-4 text-center text-xs italic text-primary opacity-90 sm:text-sm">
          We don't just serve. We care about your happiness.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
