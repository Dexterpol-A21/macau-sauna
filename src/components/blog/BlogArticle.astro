---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { SeoProps } from '../../types';

interface TocItem {
  id: string;
  label: string;
}

interface RelatedPost {
  slug: string;
  cat: string;
  title: string;
}

interface Props {
  seo: SeoProps;
  category: string;
  title: string;
  description: string;
  meta: string;
  image: string;
  imageAlt: string;
  toc: TocItem[];
  related: RelatedPost[];
}

const { seo, category, title, description, meta, image, imageAlt, toc, related } = Astro.props;
---

<BaseLayout seo={seo}>
  <article class="chrome-pad px-4 pb-14 sm:px-4 sm:pb-16">
    <div class="mx-auto max-w-6xl">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-white/40 transition-colors hover:text-primary"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        All articles
      </a>

      <header class="mt-6 max-w-3xl">
        <span
          class="inline-block rounded-full border border-primary/40 bg-[#141414] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.12em] text-primary"
        >
          {category}
        </span>
        <h1 class="mt-4 text-[1.7rem] font-bold leading-snug text-white sm:text-4xl">{title}</h1>
        <p class="mt-3 text-[15px] leading-relaxed text-white/60">{description}</p>
        <p class="mt-3 text-[13px] text-white/40">{meta}</p>
      </header>

      <div class="mt-7 max-w-3xl overflow-hidden rounded-2xl border border-white/10 shadow-sm">
        <img
          src={image}
          alt={imageAlt}
          class="aspect-[16/9] h-auto w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="mt-9 lg:grid lg:grid-cols-[minmax(0,1fr)_240px] lg:gap-12">
        <div class="min-w-0 max-w-3xl">
          {
            toc.length > 0 && (
              <details class="mb-7 rounded-xl border border-white/10 bg-[#141414] px-5 py-4 lg:hidden">
                <summary class="cursor-pointer text-[11px] font-bold uppercase tracking-[0.12em] text-primary">
                  In this article
                </summary>
                <ul class="mt-3 space-y-1.5">
                  {toc.map((item) => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        class="text-sm text-white/70 transition-colors hover:text-primary"
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            )
          }

          <div class="blog-prose">
            <slot />
          </div>

          <div class="mt-10 rounded-2xl border border-primary/15 bg-gradient-to-r from-[#141414] to-[#1a1a1a] p-6 text-center sm:p-8">
            <h2 class="mb-2 text-xl font-bold text-white sm:text-2xl">Ready to book?</h2>
            <p class="mb-5 text-sm text-white/55">
              Tell us your date and preferences — we&rsquo;ll match the venue and arrange your free shuttle.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-primary-light hover:text-[#0a0a0a]"
            >
              Contact us →
            </a>
          </div>

          {
            related.length > 0 && (
              <div class="mt-10 border-t border-white/10 pt-8">
                <p class="mb-4 text-[11px] font-bold uppercase tracking-[0.12em] text-primary">
                  Keep reading
                </p>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  {related.map((o) => (
                    <a
                      href={`/blog/${o.slug}`}
                      class="block rounded-xl border border-white/10 bg-[#141414] p-4 shadow-sm transition-all hover:border-primary/40 hover:shadow-md"
                    >
                      <span class="text-[10px] font-bold uppercase tracking-[0.1em] text-primary">
                        {o.cat}
                      </span>
                      <p class="mt-1 line-clamp-2 text-sm font-semibold text-white">{o.title}</p>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        {
          toc.length > 0 && (
            <aside class="hidden lg:block">
              <nav
                class="sticky top-24 rounded-xl border border-white/10 bg-[#141414] px-5 py-4"
                data-toc
                aria-label="Table of contents"
              >
                <p class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.12em] text-primary">
                  In this article
                </p>
                <ul class="space-y-2">
                  {toc.map((item) => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        data-toc-link={item.id}
                        class="-ml-px block border-l-2 border-transparent pl-3 text-[13px] leading-snug text-white/55 transition-colors hover:text-primary"
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .blog-prose {
    color: rgba(255, 248, 240, 0.72);
    font-size: 1rem;
    line-height: 1.75;
  }

  .blog-prose > :first-child {
    margin-top: 0;
  }

  .blog-prose p {
    margin: 0 0 1.25rem;
  }

  .blog-prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-prose a:hover {
    color: var(--color-primary-light);
  }

  .blog-prose h2 {
    margin: 2.25rem 0 0.85rem;
    scroll-margin-top: 7rem;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    color: #fff8f0;
  }

  @media (min-width: 640px) {
    .blog-prose h2 {
      font-size: 1.5rem;
    }
  }

  .blog-prose ul,
  .blog-prose ol {
    margin: 0 0 1.25rem;
    padding-left: 1.25rem;
  }

  .blog-prose ul {
    list-style: disc;
  }

  .blog-prose ol {
    list-style: decimal;
  }

  .blog-prose li {
    margin-bottom: 0.5rem;
  }

  .blog-prose li strong {
    color: #fff8f0;
  }

  .blog-prose .blog-table-wrap {
    margin: 0 0 1.5rem;
    overflow-x: auto;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .blog-prose table {
    width: 100%;
    min-width: 28rem;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .blog-prose th {
    background: #1a1a1a;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #fff8f0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .blog-prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 248, 240, 0.7);
    vertical-align: top;
  }

  .blog-prose tr:last-child td {
    border-bottom: none;
  }

  .blog-prose blockquote {
    margin: 0 0 1.25rem;
    border-left: 2px solid color-mix(in srgb, var(--color-primary) 40%, transparent);
    padding-left: 1rem;
    color: rgba(255, 248, 240, 0.5);
    font-size: 0.875rem;
    font-style: italic;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const ids = [...links].map((a) => a.dataset.tocLink!).filter(Boolean);
    const headings = ids
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);

    const setActive = (id: string | null) => {
      links.forEach((a) => {
        const on = a.dataset.tocLink === id;
        a.classList.toggle('border-primary', on);
        a.classList.toggle('text-primary', on);
        a.classList.toggle('border-transparent', !on);
        a.classList.toggle('text-white/55', !on);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]?.target?.id) setActive(visible[0].target.id);
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: [0, 1] }
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>
