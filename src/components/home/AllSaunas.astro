---
import { FEATURED_VENUES } from '../../utils/constants';
import { FILTERS, buildVenueTags } from '../../utils/filterColors';
import type { Venue } from '../../types';
import SlotMachineText from '../ui/SlotMachineText';

const DEFAULT_ACCENT = '#FF4DA6';

function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

/**
 * Bento layout spans (desktop 3-col grid only):
 *   0 = Manhao Spa          → 2 cols × 2 rows (hero)
 *   5 = The Excellent Sauna → 1 col  × 2 rows (tall)
 *   7 = M CLUB              → 2 cols × 1 row  (wide)
 *
 * Visual flow (3 cols):
 *   ┌──────────────────────┬─────────────┬─────────────┐
 *   │ Manhao (2×2)         │ Number Nine │ Shang Pin   │
 *   │                      ├─────────────┼─────────────┤
 *   │                      │ Empire      │ Majesty     │
 *   ├──────────────────────┼─────────────┼─────────────┤
 *   │ East Castle          │ The         │ Victoria    │
 *   │                      │ Excellent   │             │
 *   ├──────────────────────┤ (1×2)       ├─────────────┤
 *   │ M CLUB (wide 2 cols) │             │ Oceanic     │
 *   ├──────────────────────┼─────────────┼─────────────┤
 *   │ Number One           │ Familia     │             │
 *   └──────────────────────┴─────────────┴─────────────┘
 */
const BENTO: Record<number, { col: number; row: number }> = {
  0: { col: 2, row: 2 },   // Manhao Spa
  5: { col: 1, row: 2 },   // The Excellent Sauna
  8: { col: 2, row: 1 },   // M CLUB
  11: { col: 2, row: 1 },  // Familia Nobre
};

---

<section class="as-section" data-lenis-prevent>
  <div class="as-header">
    <h2 class="as-headline">
      <SlotMachineText text="Partner Saunas" stripLength={12} client:visible />
    </h2>
    <span class="as-subtitle">Explore All Venues</span>
    <p class="as-sub">
      From the newest luxury builds to hidden-gem values, every Macau sauna worth visiting.
    </p>
  </div>

  <div class="as-filters" data-lenis-prevent>
    {FILTERS.map((f) => (
      <button
        type="button"
        class="as-filter-btn"
        data-filter={f.key}
        style={`--f-color: ${f.color};`}
      >
        {f.label}
      </button>
    ))}
  </div>

  <div class="as-grid" data-lenis-prevent>
    {FEATURED_VENUES.map((v: Venue, i: number) => {
      const b = BENTO[i];
      const tags = buildVenueTags(v);
      const isHero = b?.col === 2 && b?.row === 2;
      const isTall = b?.row === 2 && b?.col === 1;
      const isWide = b?.col === 2 && b?.row === 1;
      const accent = tags[0]?.color ?? DEFAULT_ACCENT;
      const gridSpan = b ? `grid-column: span ${b.col}; grid-row: span ${b.row};` : '';
      const borderColor = hexToRgba(accent, 0.08);
      const hoverBorder = hexToRgba(accent, 0.4);
      const hoverShadow = `0 12px 40px ${hexToRgba(accent, 0.07)}`;
      const inlineStyle = `--card-accent: ${accent}; ${gridSpan} border-color: ${borderColor};`;
      const hoverVars = `--hover-border: ${hoverBorder}; --hover-shadow: ${hoverShadow};`;

      return (
        <a
          href={`/venues/${v.slug}`}
          class={`as-card${isHero ? ' as-card--hero' : ''}${isTall ? ' as-card--tall' : ''}${isWide ? ' as-card--wide' : ''}`}
          style={`${inlineStyle} ${hoverVars}`}
          data-categories={v.category?.join(' ') ?? ''}
        >
          <div class="as-card-media">
            <img src={v.image} alt={v.name} loading="lazy" decoding="async" />
            <div class="as-card-gradient" />
          </div>

          <div class="as-card-body">
            <div class="as-card-top">
              {tags.map((t) => (
                <span
                  class="as-tag"
                  style={t.primary
                    ? `background-color: ${t.color}; color: #0A0A0A;`
                    : `color: ${t.color}; background: transparent; border: 1px solid ${t.color}33;`}
                >
                  {t.label}
                </span>
              ))}
            </div>
            <h3 class="as-card-name">{v.name}</h3>
            <p class="as-card-tag">{v.subtitle}</p>
            <p class="as-card-desc">{v.description}</p>
            <div class="as-card-footer">
              <span class="as-card-price">{v.priceRange}</span>
              <span class="as-card-cta">Learn More &rarr;</span>
            </div>
          </div>
        </a>
      );
    })}
  </div>
  <p class="as-gallery-hint">Swipe to explore →</p>
</section>

<style is:global>
  .as-section {
    background: #0A0A0A;
    padding: 6rem 1.5rem 8rem;
    position: relative;
    z-index: 10;
    border-top: 2px solid rgba(255,77,166, 0.12);
  }

  /* ── Header ── */
  .as-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 3rem;
    padding-inline: 1rem;
  }

  .as-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #FF4DA6;
    margin-top: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .as-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #FFF8F0;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .as-sub {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    color: #9E9E9E;
    max-width: 34rem;
    line-height: 1.55;
  }

  /* ── Filter Bar ── */
  .as-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
    margin-bottom: 3rem;
    padding-inline: 1rem;
  }

  @media (max-width: 480px) {
    .as-filters {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      padding-inline: 0.5rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .as-filters::-webkit-scrollbar {
      display: none;
    }
    .as-filter-btn {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 0.4rem 0.75rem;
      font-size: 0.65rem;
    }
  }

  .as-filter-btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9E9E9E;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid color-mix(in srgb, var(--f-color, #9E9E9E) 15%, transparent);
    border-radius: 0.25rem;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .as-filter-btn:hover,
  .as-filter-btn[aria-pressed="true"] {
    color: #0A0A0A;
    background: var(--f-color, #FF4DA6);
    border-color: var(--f-color, #FF4DA6);
  }

  /* ── Bento Grid (tablet+) ── */
  .as-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    max-width: 80rem;
    margin-inline: auto;
    grid-auto-rows: minmax(300px, auto);
  }

  @media (min-width: 768px) {
    .as-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .as-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(300px, auto);
    }
  }

  .as-gallery-hint { display: none; }

  /* ── Mobile: horizontal snap gallery ── */
  @media (max-width: 767px) {
    .as-section {
      padding: 4rem 0 2rem;
      overflow: hidden;
    }
    .as-header {
      margin-bottom: 2rem;
      padding-inline: 1.25rem;
    }
    .as-headline {
      font-size: clamp(1.75rem, 8vw, 2.25rem);
    }
    .as-sub {
      font-size: 0.8rem;
    }
    .as-filters {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-inline: 1.25rem;
      margin-bottom: 1.5rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .as-filters::-webkit-scrollbar { display: none; }
    .as-filter-btn {
      flex-shrink: 0;
      white-space: nowrap;
    }

    .as-grid {
      display: flex;
      grid-template-columns: none;
      grid-auto-rows: auto;
      gap: 0.85rem;
      max-width: none;
      margin-inline: 0;
      padding-inline: 0;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 0;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .as-grid::-webkit-scrollbar { display: none; }

    .as-card {
      flex: 0 0 90vw;
      width: 90vw;
      max-width: none;
      height: 30rem;
      scroll-snap-align: start;
      grid-column: auto !important;
      grid-row: auto !important;
    }
    .as-card:first-child {
      scroll-snap-align: start;
    }
    .as-card:last-child {
      scroll-snap-align: end;
    }
    .as-card-media {
      flex: 1 1 auto;
      min-height: 0;
    }
    .as-card-body {
      padding: 0.85rem 1rem 0.75rem;
    }
    .as-card-footer {
      padding-top: 0.75rem;
      padding-bottom: 1rem;
      margin-bottom: 0;
    }
    .as-card-name { font-size: 1.15rem; }
    .as-card-desc {
      font-size: 0.75rem;
      -webkit-line-clamp: 2;
      margin-top: 0.2rem;
    }
    .as-card-cta {
      opacity: 1;
      transform: none;
    }
    .as-gallery-hint {
      display: block;
      text-align: center;
      margin-top: 0.75rem;
      padding-inline: 1.25rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,77,166, 0.45);
    }
  }

  /* ── Card Base ── */
  .as-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 0.375rem;
    overflow: hidden;
    background: #111111;
    border: 1px solid;
    text-decoration: none;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
    min-height: 0;
  }

  .as-card:hover {
    border-color: var(--hover-border);
    box-shadow: var(--hover-shadow);
  }

  /* ── Card Media ── */
  .as-card-media {
    position: relative;
    flex: 1 0 55%;
    overflow: hidden;
    min-height: 180px;
    background: #111111;
    line-height: 0;
  }

  .as-card-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }

  .as-card:hover .as-card-media img {
    transform: scale(1.04);
  }

  .as-card-gradient {
    position: absolute;
    inset: auto 0 0 0;
    height: 55%;
    background: linear-gradient(to top, #111111 0%, transparent 100%);
    pointer-events: none;
  }

  /* ── Card Body ── */
  .as-card-body {
    position: relative;
    z-index: 2;
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .as-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .as-tag {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0A0A0A;
    border-radius: 0.2rem;
  }

  .as-card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #FFF8F0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-top: 0.15rem;
  }

  .as-card-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--card-accent, #FF4DA6);
    line-height: 1.35;
    opacity: 0.9;
  }

  .as-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: #A0A0A0;
    line-height: 1.5;
    margin-top: 0.35rem;

    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .as-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .as-card-price {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #9E9E9E;
    letter-spacing: 0.03em;
  }

  .as-card-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--card-accent, #FF4DA6);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    white-space: nowrap;
  }

  .as-card:hover .as-card-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Bento Variants (desktop only) ── */
  @media (min-width: 1024px) {
    /* Hero cell (2×2) — image-first, bigger text */
    .as-card--hero .as-card-media {
      flex: 1 0 68%;
      min-height: 0;
    }

    .as-card--hero .as-card-body {
      padding: 1.25rem 1.5rem 1.5rem;
    }

    .as-card--hero .as-card-name {
      font-size: 1.35rem;
    }

    .as-card--hero .as-card-tag {
      font-size: 0.78rem;
    }

    .as-card--hero .as-card-desc {
      -webkit-line-clamp: 4;
    }

    /* Tall cell (1×2) — more headroom for description */
    .as-card--tall .as-card-media {
      flex: 1 0 62%;
      min-height: 0;
    }

    .as-card--tall .as-card-desc {
      -webkit-line-clamp: 5;
    }

    /* Wide cell (2×1) — same stacking as normal cells, image fills full width */
    .as-card--wide {
      flex-direction: column;
    }

    .as-card--wide .as-card-media {
      flex: 1 0 55%;
      min-height: 0;
    }

    .as-card--wide .as-card-gradient {
      background: linear-gradient(to top, #111111 0%, transparent 100%);
      inset: auto 0 0 0;
      height: 55%;
      width: auto;
    }

    .as-card--wide .as-card-body {
      flex-shrink: 0;
    }

    .as-card--wide .as-card-desc {
      -webkit-line-clamp: 2;
    }
  }
</style>

<script>
  (function () {
    const btns = document.querySelectorAll('.as-filter-btn');
    const cards = document.querySelectorAll('.as-card');

    if (!btns.length || !cards.length) return;

    function setActive(key: string) {
      btns.forEach((b) => {
        const el = b as HTMLButtonElement;
        el.setAttribute('aria-pressed', el.dataset.filter === key ? 'true' : 'false');
      });
    }

    const grid = document.querySelector('.as-grid') as HTMLElement | null;

    function filter(key: string) {
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const cats = el.dataset.categories ?? '';
        if (key === 'all' || cats.split(' ').includes(key)) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
      if (grid) grid.scrollTo({ left: 0, behavior: 'smooth' });
    }

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = (btn as HTMLElement).dataset.filter ?? 'all';
        setActive(key);
        filter(key);
      });
    });

    setActive('all');
  })();
</script>
