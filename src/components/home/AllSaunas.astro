---
import { FEATURED_VENUES } from '../../utils/constants';
import { FILTERS } from '../../utils/filterColors';
import type { Venue } from '../../types';

/** Match reference filter order: All → Theme → Value → New → KTV → Japan-Korea */
const SPA_FILTERS = [
  FILTERS.find((f) => f.key === 'all')!,
  FILTERS.find((f) => f.key === 'theme-rooms')!,
  FILTERS.find((f) => f.key === 'best-value')!,
  FILTERS.find((f) => f.key === 'newest')!,
  FILTERS.find((f) => f.key === 'ktv')!,
  FILTERS.find((f) => f.key === 'jpk-staff')!,
].filter(Boolean);

type GlowKind = 'gold' | 'primary' | 'silver' | 'none';

function cardGlow(v: Venue, i: number): GlowKind {
  // Reference: Manhao = red vs gold cards. Our palette maps gold→red,
  // so Manhao flips to gold for contrast against the red system.
  if (i === 0) return 'gold';
  if (i < 6 && (v.badge === 'new' || v.badge === 'popular' || v.badge === 'value')) return 'primary';
  if (i < 9) return 'silver';
  return 'none';
}

const GLOW_CLASS: Record<GlowKind, string> = {
  gold: 'fs-card--gold',
  primary: 'fs-card--primary',
  silver: 'fs-card--silver',
  none: 'fs-card--plain',
};
---

<section id="spas" class="fs-section scroll-mt-6">
  <div class="fs-wrap">
    <div class="fs-header fade-up">
      <h2 class="fs-title">All Twelve Venues</h2>
      <div class="fs-rule" aria-hidden="true"></div>
      <p class="fs-sub">
        Every partner venue — selection show, private sessions, themed rooms, and overnight stays.
      </p>
    </div>

    <div class="fs-filters-bar">
      <div class="fs-filters" role="group" aria-label="Filter saunas" data-spa-filter>
        {SPA_FILTERS.map((f) => (
          <button
            type="button"
            data-bucket={f.key}
            aria-pressed={f.key === 'all' ? 'true' : 'false'}
            class="fs-filter-btn"
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>

    <div class="fs-grid" data-spa-grid>
      {FEATURED_VENUES.map((v: Venue, i: number) => {
        const glow = cardGlow(v, i);
        const delay = (i * 0.03).toFixed(2);

        return (
          <div
            class="fade-up"
            style={`transition-delay: ${delay}s`}
            data-testid="spa-card"
            data-categories={v.category?.join(' ') ?? ''}
          >
            <a
              href={`/venues/${v.slug}`}
              class={`fs-card group ${GLOW_CLASS[glow]}`}
              data-testid="spa-card-link"
            >
              <div class="fs-card-media">
                {v.subtitle && (
                  <span class={`fs-badge ${glow === 'gold' ? 'fs-badge--gold' : 'fs-badge--primary'}`}>
                    {v.subtitle}
                  </span>
                )}
                <img
                  src={v.image}
                  alt={`${v.name} — Macau sauna venue`}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                  width="800"
                  height="600"
                  class="fs-card-img"
                />
                <div class="fs-card-shade" aria-hidden="true"></div>
              </div>
              <div class="fs-card-body">
                <h3 class="fs-card-name">{v.name}</h3>
                <p class="fs-card-desc">{v.description}</p>
                <div class="fs-card-more">
                  <span>Learn More</span>
                  <span class="fs-card-arrow">→</span>
                </div>
              </div>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .fs-section {
    --fs-gold: #d4af37;
    --fs-gold-dark: #c5a028;
    background: #0a0a0a;
    padding: 3.5rem 1rem;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 640px) {
    .fs-section {
      padding: 5rem 1rem;
    }
  }

  .fs-wrap {
    max-width: 80rem;
    margin-inline: auto;
  }

  .fs-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .fs-title {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 1.875rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }

  @media (min-width: 640px) {
    .fs-title {
      font-size: 2.25rem;
    }
  }

  .fs-rule {
    width: 5rem;
    height: 2px;
    background: var(--color-primary);
    margin: 0 auto 1.5rem;
  }

  .fs-sub {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    color: rgba(255, 255, 255, 0.5);
    max-width: 42rem;
    margin-inline: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    text-wrap: balance;
    padding-inline: 0.25rem;
  }

  /* Sticky flush under live chrome (measured in PromoBanner) */
  .fs-filters-bar {
    position: sticky;
    top: var(--sticky-under-chrome);
    z-index: 30;
    margin: 0 -1rem 1.75rem;
    padding: 0.55rem 1rem;
    background: #0a0a0a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .fs-filters {
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    align-items: center;
    gap: 0.5rem;
    max-width: 80rem;
    margin-inline: auto;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
  }

  .fs-filters::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 640px) {
    .fs-filters {
      justify-content: center;
      overflow-x: visible;
    }
  }

  .fs-filter-btn {
    flex: 0 0 auto;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: center;
    white-space: nowrap;
    border-radius: 9999px;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  @media (min-width: 640px) {
    .fs-filter-btn {
      padding: 0.375rem 0.875rem;
      font-size: 13px;
    }
  }

  .fs-filter-btn:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .fs-filter-btn[aria-pressed='true'] {
    background: var(--color-primary);
    color: #000;
    border-color: transparent;
  }

  /* Grid — equal cards like reference */
  .fs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .fs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .fs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .fs-card {
    display: block;
    background: #141414;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
  }

  .fs-card--gold {
    border-color: color-mix(in srgb, var(--fs-gold) 60%, transparent);
    animation: fs-gold-glow 2s ease-in-out infinite;
  }
  .fs-card--gold:hover {
    border-color: color-mix(in srgb, var(--fs-gold) 80%, transparent);
  }

  .fs-card--primary {
    border-color: color-mix(in srgb, var(--color-primary) 60%, transparent);
    animation: fs-primary-glow 2s ease-in-out infinite;
  }
  .fs-card--primary:hover {
    border-color: color-mix(in srgb, var(--color-primary) 80%, transparent);
  }

  .fs-card--silver {
    border-color: rgba(255, 255, 255, 0.3);
    animation: fs-silver-glow 3s ease-in-out infinite;
  }

  .fs-card--plain {
    border-color: rgba(255, 255, 255, 0.1);
  }
  .fs-card--plain:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .fs-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .fs-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    max-width: calc(100% - 1.5rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .fs-badge--gold {
    background: var(--fs-gold);
    color: #000;
  }

  .fs-badge--primary {
    background: var(--color-primary);
    color: #000;
  }

  .fs-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .group:hover .fs-card-img {
    transform: scale(1.1);
  }

  .fs-card-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent, transparent);
    opacity: 0.6;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .group:hover .fs-card-shade {
    opacity: 0.8;
  }

  .fs-card-body {
    padding: 1.25rem;
  }

  .fs-card-name {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
  }

  .group:hover .fs-card-name {
    color: var(--color-primary);
  }

  .fs-card-desc {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.625;
    color: rgba(255, 255, 255, 0.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fs-card-more {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  @media (min-width: 640px) {
    .fs-card-more {
      opacity: 0;
    }
    .group:hover .fs-card-more {
      opacity: 1;
    }
  }

  .fs-card-arrow {
    margin-left: 0.25rem;
    transition: transform 0.3s ease;
  }

  .group:hover .fs-card-arrow {
    transform: translateX(4px);
  }

  /* Entrance */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.4s ease-out,
      transform 0.4s ease-out;
  }

  .fade-up.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .fs-card--gold,
    .fs-card--primary,
    .fs-card--silver {
      animation: none;
    }
    .group:hover .fs-card-img {
      transform: none;
    }
  }

  @keyframes fs-gold-glow {
    0%,
    100% {
      box-shadow: 0 0 8px #d4af374d;
    }
    50% {
      box-shadow: 0 0 20px #d4af3799;
    }
  }

  @keyframes fs-primary-glow {
    0%,
    100% {
      box-shadow: 0 0 8px color-mix(in srgb, var(--color-primary) 30%, transparent);
    }
    50% {
      box-shadow: 0 0 22px color-mix(in srgb, var(--color-primary) 60%, transparent);
    }
  }

  @keyframes fs-silver-glow {
    0%,
    100% {
      box-shadow: 0 0 10px #c0c0d259;
    }
    50% {
      box-shadow: 0 0 22px #c0c0d2a6;
    }
  }
</style>

<script>
  (function () {
    const btns = document.querySelectorAll<HTMLButtonElement>('[data-spa-filter] .fs-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('[data-spa-grid] > [data-categories]');
    if (!btns.length || !cards.length) return;

    function setActive(key: string) {
      btns.forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.bucket === key ? 'true' : 'false');
      });
    }

    function filter(key: string) {
      cards.forEach((card) => {
        const cats = card.dataset.categories ?? '';
        const show = key === 'all' || cats.split(' ').includes(key);
        card.style.display = show ? '' : 'none';
      });
    }

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.bucket ?? 'all';
        setActive(key);
        filter(key);
      });
    });

    setActive('all');

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      document.querySelectorAll('.fade-up').forEach((el) => el.classList.add('in-view'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const t of entries) {
          if (t.isIntersecting) {
            t.target.classList.add('in-view');
            io.unobserve(t.target);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
    );
    document.querySelectorAll('.fs-section .fade-up:not(.in-view)').forEach((el) => io.observe(el));
  })();
</script>
