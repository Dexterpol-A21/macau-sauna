---
import SlotMachineText from '../ui/SlotMachineText';

const BENEFITS = [
  {
    image: '/images/why-choose/wu-selection.png',
    title: 'Selection Show',
    description: 'See therapists live and pick your match — widest selection in Macau',
  },
  {
    image: '/images/why-choose/wu-privacy.svg',
    title: 'Private Sessions',
    description: 'Private room, completely undisturbed — just you and your therapist',
  },
  {
    image: '/images/why-choose/wu-private.png',
    title: 'Themed Rooms',
    description: '20+ themed scenarios with fully customizable roleplay',
  },
  {
    image: '/images/why-choose/wu-overnight.png',
    title: 'Overnight Stay',
    description: '12–15 hours of free stay including breakfast and bathing',
  },
];
---

<section class="wub-section">
  <div class="wub-wrap">
    <div class="wub-head">
      <div class="wub-title-row">
        <h2 class="wub-title">
          <SlotMachineText text="Why Choose Us" stripLength={12} client:visible />
        </h2>
        <!-- PURE HTML/CSS ANIMATED GRAPHIC VARIANT -->
        <div class="wub-abstract-art">
          <div class="wub-ring wub-ring-1"></div>
          <div class="wub-ring wub-ring-2"></div>
          <div class="wub-ring wub-ring-3"></div>
          <div class="wub-dot"></div>
        </div>
      </div>
    </div>

    <div class="wub-bento">
      {/* 1. Private Sessions - Wide card */}
      <div class="wub-card wub-card--wide">
        <div class="wub-card-bg">
          <img src={BENEFITS[1].image} alt="" loading="lazy" decoding="async" />
        </div>
        <div class="wub-card-content">
          <span class="wub-card-num">01</span>
          <h3 class="wub-card-title">{BENEFITS[1].title}</h3>
          <p class="wub-card-desc">{BENEFITS[1].description}</p>
        </div>
      </div>

      {/* 2. Themed Rooms - Tall card */}
      <div class="wub-card wub-card--tall">
        <div class="wub-card-bg">
          <img src={BENEFITS[2].image} alt="" loading="lazy" decoding="async" />
        </div>
        <div class="wub-card-content">
          <span class="wub-card-num">02</span>
          <h3 class="wub-card-title">{BENEFITS[2].title}</h3>
          <p class="wub-card-desc">{BENEFITS[2].description}</p>
        </div>
      </div>

      {/* 3. Selection Show - Square */}
      <div class="wub-card">
        <div class="wub-card-bg">
          <img src={BENEFITS[0].image} alt="" loading="lazy" decoding="async" />
        </div>
        <div class="wub-card-content">
          <span class="wub-card-num">03</span>
          <h3 class="wub-card-title">{BENEFITS[0].title}</h3>
          <p class="wub-card-desc">{BENEFITS[0].description}</p>
        </div>
      </div>

      {/* 4. Overnight Stay - Square */}
      <div class="wub-card">
        <div class="wub-card-bg">
          <img src={BENEFITS[3].image} alt="" loading="lazy" decoding="async" />
        </div>
        <div class="wub-card-content">
          <span class="wub-card-num">04</span>
          <h3 class="wub-card-title">{BENEFITS[3].title}</h3>
          <p class="wub-card-desc">{BENEFITS[3].description}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .wub-section {
    background: #000000;
    padding: 8rem 2rem;
    border-top: 2px solid rgba(201,168,76,0.12);
  }

  .wub-wrap {
    max-width: 72rem;
    margin-inline: auto;
  }

  /* ═══════ HEAD & ANIMATION ═══════ */
  .wub-head {
    text-align: center;
    margin-bottom: 5rem;
  }

  .wub-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin: 0 0 3rem 0;
  }

  .wub-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    color: #FFF8F0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* Sits beside the title now, not stacked below it */
  .wub-abstract-art {
    position: relative;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wub-ring {
    position: absolute;
    border: 1px solid rgba(201, 168, 76, 0.4);
    border-radius: 50%;
    animation: wub-pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .wub-ring-1 {
    width: 0.9rem;
    height: 0.9rem;
    animation-delay: 0s;
  }

  .wub-ring-2 {
    width: 1.8rem;
    height: 1.8rem;
    border-color: rgba(201, 168, 76, 0.2);
    animation-delay: -2s;
  }

  .wub-ring-3 {
    width: 2.75rem;
    height: 2.75rem;
    border-color: rgba(201, 168, 76, 0.1);
    animation-delay: -4s;
  }

  .wub-dot {
    width: 6px;
    height: 6px;
    background: #C9A84C;
    border-radius: 50%;
    position: relative;
    z-index: 2;
    box-shadow: 0 0 16px 4px rgba(201, 168, 76, 0.8);
  }

  @keyframes wub-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(0.6); opacity: 0.5; }
  }

  /* ═══════ BENTO GRID ═══════ */
  .wub-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .wub-card {
    position: relative;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    overflow: hidden;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem;
    transition: border-color 0.4s ease;
  }

  .wub-card:hover {
    border-color: rgba(201, 168, 76, 0.3);
  }

  /* BIG background illustrations */
  .wub-card-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0.35;
    transition: opacity 0.5s ease;
  }

  .wub-card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 80% 80%;
    transform: scale(1.2);
  }

  .wub-card:hover .wub-card-bg {
    opacity: 0.7;
  }

  /* Gradient to ensure text is readable over the giant images */
  .wub-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #141414 15%, transparent 80%);
    z-index: 1;
  }

  .wub-card-content {
    position: relative;
    z-index: 2;
  }

  .wub-card-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #C9A84C;
    opacity: 0.5;
    margin-bottom: 1rem;
    display: block;
    line-height: 1;
  }

  .wub-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #FFF8F0;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem 0;
  }

  .wub-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: #A0A0B0;
    line-height: 1.5;
    max-width: 90%;
  }

  /* ═══════ DESKTOP BENTO LAYOUT (3 columns) ═══════ */
  @media (min-width: 1024px) {
    .wub-bento {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(250px, auto);
    }

    .wub-card--wide {
      grid-column: span 2;
      grid-row: span 1;
    }

    .wub-card--tall {
      grid-column: span 1;
      grid-row: span 2;
    }

    /* Adjust image positions for specific bento shapes */
    .wub-card--wide .wub-card-bg img {
      object-position: right center;
      transform: scale(1) translate(10%, 0);
    }
    
    .wub-card--tall .wub-card-bg img {
      object-position: top center;
      transform: scale(1.4) translate(0, -10%);
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .wub-bento {
      grid-template-columns: 1fr 1fr;
    }
    .wub-card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 639px) {
    .wub-section {
      padding: 5rem 1.25rem;
    }
    .wub-title-row {
      gap: 0.75rem;
    }
    .wub-abstract-art,
    .wub-ring-3 {
      width: 2rem;
      height: 2rem;
    }
    .wub-ring-1 {
      width: 0.65rem;
      height: 0.65rem;
    }
    .wub-ring-2 {
      width: 1.3rem;
      height: 1.3rem;
    }
    .wub-card {
      min-height: 260px;
      padding: 1.5rem;
    }
    .wub-card-title {
      font-size: 1.4rem;
    }
    .wub-card-desc {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 420px) {
    .wub-section {
      padding: 4rem 0.75rem;
    }
    .wub-head {
      margin-bottom: 3rem;
    }
    .wub-title-row {
      gap: 0.5rem;
      margin-bottom: 2rem;
    }
    .wub-abstract-art,
    .wub-ring-3 {
      width: 1.5rem;
      height: 1.5rem;
    }
    .wub-ring-1 {
      width: 0.5rem;
      height: 0.5rem;
    }
    .wub-ring-2 {
      width: 1rem;
      height: 1rem;
    }
    .wub-bento {
      gap: 0.75rem;
    }
    .wub-card {
      min-height: 220px;
      padding: 1.25rem;
    }
    .wub-card-num {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .wub-card-title {
      font-size: 1.2rem;
    }
    .wub-card-desc {
      font-size: 0.78rem;
      max-width: 100%;
    }
  }
</style>
