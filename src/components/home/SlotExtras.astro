---
import SlotMachineText from '../ui/SlotMachineText';
import SlotMatch from '../smart-match/SlotMatch';
import { Sparkles, Feather, Brain, Footprints, Hand, HandHeart, Ear } from '@lucide/astro';

const VIP_EXTRAS = [
  { service: 'Back Rubbing', note: 'Body-glide rub down the back, neck and shoulders.', value: '298 MOP', Icon: Sparkles },
  { service: 'Relaxable Thigh Massage', note: 'Deep work on quads & hamstrings, perfect after the sauna.', value: '288 MOP', Icon: Feather },
  { service: 'Head Massage', note: 'Scalp kneading that clears mental fog and headaches.', value: '230 MOP', Icon: Brain },
  { service: 'Reflexology', note: 'Pressure-point work that revives tired feet.', value: '230 MOP', Icon: Footprints },
  { service: 'Manicure', note: 'Trim, shape, cuticle care, polish.', value: '220 MOP', Icon: Hand },
  { service: 'Pedicure', note: 'Foot soak, nail and cuticle care, light foot rub.', value: '220 MOP', Icon: Footprints },
  { service: 'Hand Massage', note: 'Releases wrist and forearm tension.', value: '200 MOP', Icon: HandHeart },
  { service: 'Ear Cleaning', note: 'Traditional ear-cleaning ritual. Surprisingly relaxing.', value: '200 MOP', Icon: Ear },
];
---

<section id="slot-extras" class="se-section">
  <div class="se-wrap">
    <div class="se-head se-head--compact">
      <h2 class="se-title">
        <SlotMachineText text="WIN A FREEBIE" stripLength={8} client:visible />
      </h2>
      <p class="se-sub">Celebrate our new opening &mdash; pull the lever and match 3 symbols to win 1 free treatment per visit!</p>
    </div>

    <div class="se-slot">
      <SlotMatch client:visible />
    </div>

    <div class="se-head">
      <h2 class="se-title">
        <SlotMachineText text="Pick 1, served by pretty girls" stripLength={12} client:visible />
      </h2>
      <span class="se-label">What You Can Win</span>
    </div>

    <div class="se-list">
      {VIP_EXTRAS.map((row) => (
        <div class="se-extra">
          <div class="se-extra-icon">
            <row.Icon class="w-6 h-6" />
          </div>
          <div class="se-extra-info">
            <h4 class="se-extra-name">{row.service}</h4>
            <p class="se-extra-note">{row.note}</p>
          </div>
          <div class="se-extra-right">
            <span class="se-extra-price">{row.value}</span>
            <span class="se-extra-badge">1 Free / Visit</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .se-section {
    background: #0A0A0A;
    padding: var(--chrome-pad) 2rem 8rem;
    border-top: 2px solid rgba(255,45,85,0.12);
  }

  .se-wrap {
    max-width: 64rem;
    margin-inline: auto;
  }

  .se-head {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .se-head--compact {
    margin-bottom: 2rem;
  }

  .se-title {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    color: #FFF8F0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .se-label {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #FF2D55;
    display: block;
    margin-top: 0.75rem;
  }

  .se-sub {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: #9E9E9E;
    max-width: 30rem;
    margin: 0.75rem auto 0;
    line-height: 1.55;
  }

  .se-slot {
    margin-bottom: 3rem;
  }

  .se-list {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,45,85,0.10);
    border-radius: 0.5rem;
    overflow: hidden;
    background: #121212;
    max-width: 56rem;
    margin-inline: auto;
  }

  .se-extra {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    transition: background 0.3s ease;
  }

  .se-extra:last-child { border-bottom: none; }
  .se-extra:hover { background: rgba(255,45,85,0.03); }

  .se-extra-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.5rem;
    background: rgba(255,45,85,0.05);
    color: #FF2D55;
    flex-shrink: 0;
  }

  .se-extra-info { flex: 1; min-width: 0; }

  .se-extra-name {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #EDEDED;
    line-height: 1.2;
    margin: 0 0 0.2rem;
  }

  .se-extra-note {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #B0A890;
    line-height: 1.45;
    margin: 0;
  }

  .se-extra-right {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .se-extra-price {
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #B0A890;
    text-decoration: line-through;
    white-space: nowrap;
  }

  .se-extra-badge {
    display: inline-block;
    padding: 0.35rem 1.15rem;
    font-family: 'Noto Sans TC', system-ui, sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FFF8F0;
    background: linear-gradient(135deg, #FF2D55 0%, #EBD392 50%, #B8942E 100%);
    border: 1px solid rgba(255,45,85,0.3);
    border-radius: 0.25rem;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .se-section { padding: var(--chrome-pad) 1.25rem 6rem; }
    .se-head { margin-bottom: 3rem; }
    .se-extra {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
    }
    .se-extra-icon {
      width: 2.5rem;
      height: 2.5rem;
    }
    .se-extra-name { font-size: 1rem; }
    .se-extra-right {
      flex-direction: row;
      gap: 0.75rem;
      width: 100%;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (max-width: 420px) {
    .se-section { padding: var(--chrome-pad) 0.75rem 5rem; }
    .se-head { margin-bottom: 2.5rem; }
    .se-head--compact { margin-bottom: 1.5rem; }
    .se-sub { font-size: 0.8rem; padding-inline: 0.5rem; }
    .se-slot { margin-bottom: 2rem; }
    .se-extra {
      padding: 1rem;
      gap: 0.75rem;
    }
    .se-extra-icon {
      width: 2rem;
      height: 2rem;
    }
    .se-extra-name { font-size: 0.95rem; }
    .se-extra-note { font-size: 0.72rem; }
    .se-extra-price { font-size: 0.7rem; }
    .se-extra-badge {
      padding: 0.3rem 0.9rem;
      font-size: 0.55rem;
    }
  }
</style>
