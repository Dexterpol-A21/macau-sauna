---
const WA =
  "https://wa.me/85365670348?text=" +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");
const TG =
  'https://t.me/Aomensauna?text=' +
  encodeURIComponent("I'm interested in Macau sauna. Could you help arrange this?");

const PLATFORMS = [
  { name: 'WhatsApp', handle: 'Message us', href: WA, color: '#25D366', kind: 'wa' },
  { name: 'Telegram', handle: '@Aomensauna', href: TG, color: '#2AABEE', kind: 'tg' },
  { name: 'WeChat', handle: 'AN99348', href: null, color: '#07C160', kind: 'wc' },
  { name: 'LINE', handle: '16880348', href: 'https://line.me/ti/p/VZHFDSZnq9', color: '#06C755', kind: 'ln' },
];

