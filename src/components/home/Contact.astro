---

<section id="contact" class="scroll-mt-6 px-4 pb-16 pt-12 sm:pb-24 sm:pt-16">
  <div class="mx-auto max-w-3xl">
    <div class="fade-up mb-10 text-center sm:mb-12">
      <h2 class="mb-3 text-2xl font-bold text-white sm:text-3xl">Just ask us</h2>
      <div class="mx-auto mb-4 h-0.5 w-16 bg-[var(--color-primary)]" aria-hidden="true"></div>
      <p class="mx-auto max-w-xl text-sm text-white/50 sm:text-base">
        Free booking help, free hotel pick-up, 24-hour English support — reply within minutes.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {PLATFORMS.map((p, i) =>
        p.href ? (
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class="fade-up group flex w-full items-center gap-4 rounded-xl border border-white/5 bg-[#141414] p-2.5 text-left transition-all duration-300 hover:border-[color-mix(in_srgb,var(--color-primary)_30%,transparent)]"
            style={`--fade-delay: ${(0.05 + i * 0.07).toFixed(2)}s`}
          >
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-[color-mix(in_srgb,var(--color-primary)_10%,transparent)] transition-colors group-hover:bg-[color-mix(in_srgb,var(--color-primary)_20%,transparent)]"
              style={`color:${p.color}`}
              set:html={ICONS[p.kind]}
            />
            <div>
              <div class="mb-1 text-xs text-white/40">{p.name}</div>
              <div class="font-medium text-white">{p.handle}</div>
            </div>
          </a>
        ) : (
          <button
            type="button"
            data-wechat-open
            class="fade-up group flex w-full items-center gap-4 rounded-xl border border-white/5 bg-[#141414] p-2.5 text-left transition-all duration-300 hover:border-[color-mix(in_srgb,var(--color-primary)_30%,transparent)]"
            style={`--fade-delay: ${(0.05 + i * 0.07).toFixed(2)}s`}
          >
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl bg-[color-mix(in_srgb,var(--color-primary)_10%,transparent)] transition-colors group-hover:bg-[color-mix(in_srgb,var(--color-primary)_20%,transparent)]"
              style={`color:${p.color}`}
              set:html={ICONS[p.kind]}
            />
            <div>
              <div class="mb-1 text-xs text-white/40">{p.name}</div>
              <div class="font-medium text-white">{p.handle}</div>
            </div>
          </button>
        )
      )}
    </div>

    <p class="fade-up mt-10 text-center text-base italic text-white/80 sm:mt-12 sm:text-lg">
      We don't just serve. We care about your happiness.
    </p>
    <p class="fade-up mx-auto mt-3 max-w-xl text-center text-sm leading-relaxed text-white/45">
      One message, and the whole night is arranged — venue, shuttle, VIP entry, and extras.
    </p>

    <div class="mt-10 text-center">
      <a href="#top" class="text-sm font-semibold text-white/45 transition-colors hover:text-[var(--color-primary)]">
        ↑ Back to Top
      </a>
    </div>
  </div>
</section>

<dialog id="wechat-modal" class="cu-dialog">
  <form method="dialog" class="cu-dialog-card">
    <h3>WeChat</h3>
    <p>Add us on WeChat with this ID:</p>
    <p class="cu-wechat-id">AN99348</p>
    <button type="button" id="wechat-copy" class="cu-copy">Copy ID</button>
    <button type="submit" class="cu-dialog-close" value="cancel">Close</button>
  </form>
</dialog>

<style>
  .cu-dialog {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 24rem;
    width: calc(100% - 2rem);
  }
  .cu-dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
  }
  .cu-dialog-card {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 1.5rem;
    text-align: center;
    color: #fff;
  }
  .cu-dialog-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
  }
  .cu-dialog-card p {
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9rem;
  }
  .cu-wechat-id {
    font-family: ui-monospace, monospace !important;
    font-size: 1.5rem !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em;
    color: var(--color-primary) !important;
    margin-bottom: 1.25rem !important;
  }
  .cu-copy {
    display: inline-block;
    border: none;
    border-radius: 9999px;
    background: var(--color-primary);
    color: #000;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
    cursor: pointer;
    margin-right: 0.5rem;
  }
  .cu-dialog-close {
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 9999px;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
    cursor: pointer;
  }
</style>

<script>
  (function () {
    const modal = document.getElementById('wechat-modal') as HTMLDialogElement | null;
    const openers = document.querySelectorAll('[data-wechat-open]');
    const copyBtn = document.getElementById('wechat-copy');
    if (!modal) return;

    openers.forEach((btn) => {
      btn.addEventListener('click', () => modal.showModal());
    });

    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('AN99348');
      } catch {
        /* ignore */
      }
      modal.close();
    });
  })();
</script>
