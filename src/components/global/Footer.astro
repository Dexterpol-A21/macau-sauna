---
import { SITE_TITLE } from '../../utils/constants';

const year = new Date().getFullYear();

const LINKS = [
  { label: 'Spas', href: '/#spas' },
  { label: 'Ranking', href: '/ranking' },
  { label: 'Guide', href: '/how-it-works' },
  { label: 'FAQ', href: '/faq' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Shuttle', href: '/shuttle' },
  { label: 'Contact', href: '#', openContact: true },
  { label: 'Privacy', href: '/privacy' },
] as const;
---

<footer class="mc-footer">
  <div class="mc-footer-inner">
    <div class="mc-footer-top">
      <button type="button" data-back-to-top class="mc-back-top">
        ↑ Back to Top
      </button>
    </div>

    <nav aria-label="Footer" class="mc-footer-nav">
      {
        LINKS.map((link, i) => (
          <span class="mc-footer-item">
            {
              i > 0 && (
                <span class="mc-footer-sep" aria-hidden="true">
                  ·
                </span>
              )
            }
            {
              'openContact' in link && link.openContact ? (
                <button type="button" data-open-contact class="mc-footer-link">
                  {link.label}
                </button>
              ) : (
                <a href={link.href} class="mc-footer-link">
                  {link.label}
                </a>
              )
            }
          </span>
        ))
      }
    </nav>

    <div class="mc-footer-brand-row">
      <a href="/" class="mc-footer-brand">{SITE_TITLE}</a>
      <p class="mc-footer-copy">
        © {year} {SITE_TITLE}.&nbsp;<br class="mc-footer-br" />All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('[data-back-to-top]').forEach((btn) => {
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>

<style>
  .mc-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    position: relative;
    z-index: 10;
  }

  .mc-footer-inner {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  @media (min-width: 640px) {
    .mc-footer-inner {
      padding-inline: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .mc-footer-inner {
      padding-inline: 2rem;
    }
  }

  .mc-footer-top {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .mc-back-top {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .mc-back-top:hover {
    color: var(--color-primary);
  }

  .mc-footer-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    column-gap: 0.75rem;
    row-gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
  }

  @media (min-width: 640px) {
    .mc-footer-nav {
      column-gap: 1.25rem;
    }
  }

  .mc-footer-item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .mc-footer-item {
      gap: 1.25rem;
    }
  }

  .mc-footer-link {
    font-family: var(--font-body);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: inherit;
  }

  .mc-footer-link:hover {
    color: var(--color-primary);
  }

  .mc-footer-sep {
    color: var(--color-border);
    user-select: none;
  }

  .mc-footer-brand-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .mc-footer-brand-row {
      flex-direction: row;
      justify-content: center;
      gap: 2rem;
    }
  }

  .mc-footer-brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mc-footer-brand:hover {
    color: var(--color-primary-light);
  }

  .mc-footer-copy {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .mc-footer-br {
    display: block;
  }

  @media (min-width: 640px) {
    .mc-footer-br {
      display: none;
    }
  }
</style>
