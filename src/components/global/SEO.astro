---
import type { SeoProps } from '../../types';
import { SITE_TITLE, CONTACT } from '../../utils/constants';

const {
  title,
  description,
  keywords,
  image = '/logo.svg',
  canonical,
  noindex = false,
  imageWidth = '64',
  imageHeight = '64',
} = Astro.props;

const siteUrl = Astro.site || 'https://macausauna.com';
const fullImage = new URL(image, siteUrl).href;
const fullCanonical = canonical ? new URL(canonical, siteUrl).href : undefined;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: SITE_TITLE,
      url: siteUrl,
      description: description,
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteUrl}/venues?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "Organization",
      name: SITE_TITLE,
      url: siteUrl,
      logo: new URL("/logo.svg", siteUrl).href,
      description: description,
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        availableLanguage: ["English", "Chinese"],
        telephone: CONTACT.whatsapp,
      },
      sameAs: [
        "https://t.me/Aomensauna",
      ],
    },
  ],
});
---

<title>{title}</title>
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<link rel="canonical" href={fullCanonical || Astro.url.href} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={jsonLd}></script>

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:image" content={fullImage} />
<meta property="og:image:width" content={imageWidth} />
<meta property="og:image:height" content={imageHeight} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Aurelia Concierge" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />

<!-- Preconnects -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- Async font loading: non-render-blocking, saves ~750ms on mobile -->
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@600;700;800&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@600;700;800&display=swap"
    rel="stylesheet"
  />
</noscript>
